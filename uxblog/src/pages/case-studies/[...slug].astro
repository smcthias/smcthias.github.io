---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { creativeWorkSchema, breadcrumbListSchema, SITE_URL } from '@/lib/schema';

export async function getStaticPaths() {
  const caseStudies = await getCollection('case-studies');
  return caseStudies.map((study) => ({
    params: { slug: study.id },
    props: { study },
  }));
}

const { study } = Astro.props;
const { Content } = await render(study);

const caseUrl = `${SITE_URL}/case-studies/${study.id}`;
const pageSchema = [
  creativeWorkSchema({
    name: study.data.title,
    description: study.data.description,
    url: caseUrl,
    image: study.data.thumbnail,
    datePublished: study.data.publishDate.toISOString().slice(0, 10),
    keywords: study.data.tags,
    about: study.data.project,
  }),
  breadcrumbListSchema([
    { name: 'Home', url: SITE_URL },
    { name: 'Case Studies', url: `${SITE_URL}/work` },
    { name: study.data.client, url: caseUrl },
  ]),
];
---

<BaseLayout
  title={`${study.data.title} - ${study.data.client}`}
  description={study.data.description}
  image={study.data.thumbnail}
  schema={pageSchema}
>
  <Breadcrumbs items={[
    { label: 'Case Studies', href: '/work' },
    { label: study.data.client, href: `/case-studies/${study.id}` },
  ]} />

  <!-- Hero Header -->
  <section class="container-custom pt-16 pb-10">
    <div class="flex flex-col lg:flex-row gap-10 lg:gap-16 mb-10">
      <!-- Left: client + title -->
      <div class="lg:w-1/2">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-bold text-gray-100 leading-tight">
          {study.data.client}
        </h1>
      </div>

      <!-- Right: description -->
      <div class="lg:w-1/2 flex items-end">
        <p class="text-lg text-gray-300 leading-relaxed">
          {study.data.description}
        </p>
      </div>
    </div>

    <!-- Metadata row -->
    <div class="border-t border-zinc-800 divide-y divide-zinc-800 lg:divide-y-0 lg:flex lg:divide-x lg:divide-zinc-800">
      <div class="py-4 lg:pr-10">
        <p class="text-sm text-gray-500 mb-1">Years</p>
        <p class="text-gray-100">
          {study.data.yearEnd ? `${study.data.year}–${study.data.yearEnd}` : study.data.year}
        </p>
      </div>

      {study.data.role && (
        <div class="py-4 lg:px-10">
          <p class="text-sm text-gray-500 mb-1">Role</p>
          <p class="text-gray-100">{study.data.role}</p>
        </div>
      )}

      {study.data.scope && (
        <div class="py-4 lg:px-10">
          <p class="text-sm text-gray-500 mb-1">Scope</p>
          <p class="text-gray-100">{study.data.scope}</p>
        </div>
      )}

      {study.data.tags.length > 0 && !study.data.scope && (
        <div class="py-4 lg:px-10">
          <p class="text-sm text-gray-500 mb-1">Scope</p>
          <p class="text-gray-100">{study.data.tags.join(', ')}</p>
        </div>
      )}

      {study.data.media && study.data.media.length > 0 && (
        <div class="py-4 lg:px-10">
          <p class="text-sm text-gray-500 mb-1">Media</p>
          <div class="flex flex-wrap gap-x-3 gap-y-1">
            {study.data.media.map((item) => (
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-100 hover:text-gray-300 transition-colors inline-flex items-center gap-0.5"
              >
                {item.label}
                <svg class="w-3 h-3 ml-0.5" viewBox="0 0 12 12" fill="none">
                  <path d="M3.5 8.5L8.5 3.5M8.5 3.5H5M8.5 3.5V7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Hero Image -->
  <section class="container-custom mb-16">
    <div class="rounded-2xl overflow-hidden">
      <img
        src={study.data.thumbnail}
        alt={study.data.client}
        class="w-full object-cover"
      />
    </div>
  </section>

  <!-- Main Content -->
  <section class="container-custom mb-16">
    <div class="prose-custom">
      <Content />
    </div>
  </section>

  <!-- Outcomes -->
  {study.data.outcomes && study.data.outcomes.length > 0 && (
    <section class="container-custom mb-16">
      <div class="border-t border-zinc-800 pt-10 grid grid-cols-1 lg:grid-cols-[180px_1fr] gap-8 lg:gap-16">
        <div>
          <p class="text-xs font-medium text-gray-500 uppercase tracking-widest pt-1">Outcomes</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 sm:gap-12">
          {study.data.outcomes.map((outcome) => (
            <div>
              <p class="text-4xl lg:text-5xl font-display font-bold text-gray-100 leading-none mb-3">{outcome.stat}</p>
              <p class="text-sm text-gray-400 leading-snug">{outcome.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Navigation -->
  <section class="container-custom py-16">
    <div class="flex items-center justify-between border-t border-zinc-800 pt-8">
      <a
        href="/work"
        class="inline-flex items-center text-gray-400 hover:text-gray-100 transition-colors"
      >
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        View Case Studies
      </a>
      <a
        href="/contact"
        class="btn-primary"
      >
        Let's Work Together
      </a>
    </div>
  </section>
</BaseLayout>
