---
import BaseLayout from '@layouts/BaseLayout.astro';
import { profilePageSchema, SITE_URL } from '@/lib/schema';

const pageSchema = profilePageSchema(`${SITE_URL}/about`);
---

<style>
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .logo-marquee {
    animation: marquee 40s linear infinite;
  }
  .logo-marquee:hover {
    animation-play-state: paused;
  }
</style>

<BaseLayout
  title="About — Savelle McThias | Product Designer & Creative Director"
  description="Two decades designing for brands like PetSmart, Plexus Worldwide, and Green Compass. Savelle McThias is a product designer and creative director based in Scottsdale, Arizona — available for local projects and remote senior roles."
  schema={pageSchema}
>
  <!-- Hero Section -->
  <section class="relative container-custom pt-32 pb-20 overflow-hidden">
    <!-- Desert landscape line art -->
    <svg
      class="absolute inset-0 w-full h-full pointer-events-none select-none"
      viewBox="0 0 1400 600"
      preserveAspectRatio="xMidYMid slice"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <!-- Mountains -->
      <polyline points="0,600 180,280 320,420 500,180 680,380 820,240 1000,400 1150,200 1320,360 1400,300 1400,600" stroke="rgba(255,255,255,0.055)" stroke-width="1.5" stroke-linejoin="round" />
      <polyline points="0,600 140,340 280,460 460,230 640,420 780,290 960,440 1100,250 1270,390 1400,340 1400,600" stroke="rgba(255,255,255,0.03)" stroke-width="1" stroke-linejoin="round" />

      <!-- Saguaro cactus left -->
      <g stroke="rgba(255,255,255,0.07)" stroke-width="1.5" stroke-linecap="round">
        <!-- trunk -->
        <line x1="1100" y1="600" x2="1100" y2="380" />
        <!-- left arm -->
        <polyline points="1100,460 1068,460 1068,410" />
        <!-- right arm -->
        <polyline points="1100,430 1132,430 1132,385" />
      </g>

      <!-- Saguaro cactus right -->
      <g stroke="rgba(255,255,255,0.055)" stroke-width="1.5" stroke-linecap="round">
        <line x1="1220" y1="600" x2="1220" y2="420" />
        <polyline points="1220,490 1196,490 1196,450" />
        <polyline points="1220,465 1244,465 1244,430" />
      </g>

      <!-- Tall saguaro far right -->
      <g stroke="rgba(255,255,255,0.04)" stroke-width="1.2" stroke-linecap="round">
        <line x1="1340" y1="600" x2="1340" y2="390" />
        <polyline points="1340,470 1318,470 1318,435" />
      </g>

      <!-- Agave bottom left -->
      <g stroke="rgba(255,255,255,0.06)" stroke-width="1.2" stroke-linecap="round">
        <line x1="80" y1="600" x2="60" y2="545" />
        <line x1="80" y1="600" x2="50" y2="560" />
        <line x1="80" y1="600" x2="40" y2="580" />
        <line x1="80" y1="600" x2="80" y2="535" />
        <line x1="80" y1="600" x2="110" y2="545" />
        <line x1="80" y1="600" x2="120" y2="562" />
        <line x1="80" y1="600" x2="118" y2="580" />
      </g>

      <!-- Agave mid right -->
      <g stroke="rgba(255,255,255,0.05)" stroke-width="1.2" stroke-linecap="round">
        <line x1="960" y1="600" x2="938" y2="548" />
        <line x1="960" y1="600" x2="928" y2="563" />
        <line x1="960" y1="600" x2="930" y2="582" />
        <line x1="960" y1="600" x2="960" y2="540" />
        <line x1="960" y1="600" x2="985" y2="548" />
        <line x1="960" y1="600" x2="992" y2="564" />
        <line x1="960" y1="600" x2="988" y2="582" />
      </g>

      <!-- Ground line -->
      <line x1="0" y1="598" x2="1400" y2="598" stroke="rgba(255,255,255,0.04)" stroke-width="1" />
    </svg>

    <div class="max-w-4xl relative">
      <h1 class="text-5xl md:text-6xl font-bold text-gray-100 mb-8 tracking-tight leading-tight">
        Designer. Builder. Desert dweller.
      </h1>
      <div class="prose prose-lg max-w-none text-gray-400 space-y-6">
        <p class="text-xl leading-relaxed">
          My superpower is a mix of intuition and ideas that seem obvious to me but apparently aren't obvious to everyone else. I've been taking things apart and putting them back together differently since I was a kid. Remote controlled cars, mostly. In high school I taught myself HTML and CSS in the school library and helped redesign sections of the school website. Nobody asked me to. I just wanted to see if I could.
        </p>
        <p class="text-lg leading-relaxed">
          Four decades of that same curiosity later and it's just how I think. Pattern recognition, creative problem solving, and a stubborn belief that most things can be done better. Those aren't skills I developed, they're just how I'm wired.
        </p>
        <p class="text-lg leading-relaxed">
          I'm based in Scottsdale with my bull terrier Diego, who makes life considerably stranger. I've spent the last decade practicing tarot as a genuine decision-making framework, which sounds unusual until you realize it's really just a structured way to slow down and trust your instincts. I even built my own app for it. I also run a YouTube channel with about 50K subscribers built on gaming and music, and somewhere in the long-term plan is either retiring to make music full time or opening a karaoke bar. Whichever comes first.
        </p>
      </div>
    </div>
  </section>

  <!-- Logo Bar -->
  <section class="py-10 border-t border-zinc-800/60">
    <p class="text-center text-xs font-medium text-gray-500 uppercase tracking-widest mb-8">
      Brands I've Worked With
    </p>
    <div class="overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_12%,black_88%,transparent)]">
      <div class="logo-marquee flex gap-20 items-center w-max">
        {[
          { src: '/images/logos/logo-bareminerals.svg',   alt: 'bareMinerals',    h: 'h-[20px]' },
          { src: '/images/logos/logo-capitolrecords.svg', alt: 'Capitol Records', h: 'h-[56px]' },
          { src: '/images/logos/logo-gm.svg',             alt: 'GM',              h: 'h-[56px]' },
          { src: '/images/logos/logo-petsmart.svg',       alt: 'PetSmart',        h: 'h-[42px]' },
          { src: '/images/logos/logo-richdad.svg',        alt: 'Rich Dad',        h: 'h-[20px]' },
          { src: '/images/logos/logo-sanity.svg',         alt: 'Sanity',          h: 'h-7'      },
          { src: '/images/logos/logo-sothebys.svg',       alt: "Sotheby's",       h: 'h-7'      },
          { src: '/images/logos/logo-thebeachboys.svg',   alt: 'The Beach Boys',  h: 'h-[56px]' },
          { src: '/images/logos/logo-universal.svg',      alt: 'Universal',       h: 'h-[56px]' },
          { src: '/images/logos/logo-bareminerals.svg',   alt: 'bareMinerals',    h: 'h-[20px]' },
          { src: '/images/logos/logo-capitolrecords.svg', alt: 'Capitol Records', h: 'h-[56px]' },
          { src: '/images/logos/logo-gm.svg',             alt: 'GM',              h: 'h-[56px]' },
          { src: '/images/logos/logo-petsmart.svg',       alt: 'PetSmart',        h: 'h-[42px]' },
          { src: '/images/logos/logo-richdad.svg',        alt: 'Rich Dad',        h: 'h-[20px]' },
          { src: '/images/logos/logo-sanity.svg',         alt: 'Sanity',          h: 'h-7'      },
          { src: '/images/logos/logo-sothebys.svg',       alt: "Sotheby's",       h: 'h-7'      },
          { src: '/images/logos/logo-thebeachboys.svg',   alt: 'The Beach Boys',  h: 'h-[56px]' },
          { src: '/images/logos/logo-universal.svg',      alt: 'Universal',       h: 'h-[56px]' },
        ].map(({ src, alt, h }) => (
          <img
            src={src}
            alt={alt}
            class={`${h} w-auto object-contain brightness-0 invert opacity-40 shrink-0`}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Experience Timeline -->
  <section class="bg-zinc-900 py-20">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
      <h2 class="text-sm font-semibold text-gray-100 uppercase tracking-wider mb-12">
        Professional Experience
      </h2>

      <div class="space-y-12">
        <!-- Savelle LLC -->
        <div class="relative pl-8 border-l-2 border-gray-100">
          <div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-gray-100"></div>
          <div class="mb-3">
            <h3 class="text-2xl font-semibold text-gray-100">Founder & Principal Designer</h3>
            <p class="text-gray-400 font-medium">Savelle LLC • March 2021 - Present</p>
            <p class="text-sm text-gray-400 mt-1">Scottsdale, AZ</p>
          </div>
          <p class="text-gray-300 leading-relaxed mb-3">
            Providing comprehensive digital experience design and development services to clients across multiple industries. Specializing in AI-augmented workflows that accelerate delivery timelines while maintaining design quality. Leveraging modern frameworks and design systems to create scalable, maintainable solutions that drive measurable business results.
          </p>
        </div>

        <!-- Green Compass -->
        <div class="relative pl-8 border-l-2 border-zinc-600">
          <div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-zinc-600"></div>
          <div class="mb-3">
            <h3 class="text-2xl font-semibold text-gray-100">Digital Experience Director</h3>
            <p class="text-gray-400 font-medium">Green Compass, LLC • February 2024 - November 2024</p>
            <p class="text-sm text-gray-400 mt-1">Scottsdale, AZ</p>
          </div>
          <p class="text-gray-300 leading-relaxed mb-3">
            Led comprehensive digital transformation initiatives, implementing modern development practices and data-driven strategies to optimize performance and user engagement.
          </p>
          <ul class="list-disc list-inside text-gray-300 space-y-2 text-sm">
            <li>Architected multi-channel digital marketing strategies leveraging analytics for campaign optimization</li>
            <li>Built and mentored high-performing digital marketing team with agile workflows</li>
            <li>Spearheaded component-based design systems and reusable pattern libraries</li>
            <li>Directed responsive web development using modern frameworks ensuring accessibility compliance</li>
            <li>Established robust analytics infrastructure with custom dashboards for real-time monitoring</li>
          </ul>
        </div>

        <!-- iFoodDS -->
        <div class="relative pl-8 border-l-2 border-zinc-600">
          <div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-zinc-600"></div>
          <div class="mb-3">
            <h3 class="text-2xl font-semibold text-gray-100">UI/UX Designer</h3>
            <p class="text-gray-400 font-medium">iFoodDS • January 2020 - March 2021</p>
            <p class="text-sm text-gray-400 mt-1">Scottsdale, Arizona</p>
          </div>
          <p class="text-gray-300 leading-relaxed mb-3">
            Modernized user experience for a complex agriculture SaaS platform serving both mobile and desktop users.
          </p>
          <ul class="list-disc list-inside text-gray-300 space-y-2 text-sm">
            <li>Redesigned core workflows reducing task completion time and support tickets</li>
            <li>Implemented responsive design patterns with modern JavaScript frameworks</li>
            <li>Collaborated with backend developers to optimize API integration</li>
          </ul>
        </div>

        <!-- SyberSafe -->
        <div class="relative pl-8 border-l-2 border-zinc-600">
          <div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-zinc-600"></div>
          <div class="mb-3">
            <h3 class="text-2xl font-semibold text-gray-100">Front-end UI Developer</h3>
            <p class="text-gray-400 font-medium">SyberSafe • February 2019 - November 2019</p>
            <p class="text-sm text-gray-400 mt-1">Chandler, Arizona</p>
          </div>
          <p class="text-gray-300 leading-relaxed mb-3">
            Contributed to the design and development of a cybersecurity compliance SaaS platform.
          </p>
          <ul class="list-disc list-inside text-gray-300 space-y-2 text-sm">
            <li>Built scalable UI components using Angular and .NET frameworks</li>
            <li>Created comprehensive brand identity and marketing collateral</li>
            <li>Implemented responsive layouts optimized for complex data visualization</li>
          </ul>
        </div>

        <!-- Plexus Worldwide -->
        <div class="relative pl-8 border-l-2 border-zinc-600">
          <div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-zinc-600"></div>
          <div class="mb-3">
            <h3 class="text-2xl font-semibold text-gray-100">UI/UX Designer</h3>
            <p class="text-gray-400 font-medium">Plexus Worldwide • August 2016 - February 2019</p>
            <p class="text-sm text-gray-400 mt-1">Scottsdale, AZ</p>
          </div>
          <p class="text-gray-300 leading-relaxed mb-3">
            Pioneered digital design function for marketing team, leading three major platform redesigns.
          </p>
          <ul class="list-disc list-inside text-gray-300 space-y-2 text-sm">
            <li>Architected custom <span class="whitespace-nowrap">e-commerce</span> platform and back-office dashboard serving thousands</li>
            <li>Developed atomic design system improving design-to-development handoff by 60%</li>
            <li>Conducted extensive A/B testing and analytics analysis for iterative improvements</li>
          </ul>
        </div>

        <!-- PetSmart -->
        <div class="relative pl-8 border-l-2 border-zinc-600">
          <div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-zinc-600"></div>
          <div class="mb-3">
            <h3 class="text-2xl font-semibold text-gray-100">Senior Web Designer</h3>
            <p class="text-gray-400 font-medium">PetSmart • September 2015 - July 2016</p>
            <p class="text-sm text-gray-400 mt-1">Greater Phoenix Area</p>
          </div>
          <p class="text-gray-300 leading-relaxed mb-3">
            Contributed to major <span class="whitespace-nowrap">e-commerce</span> redesign initiative focused on conversion optimization.
          </p>
          <ul class="list-disc list-inside text-gray-300 space-y-2 text-sm">
            <li>Participated in comprehensive site redesign based on A/B testing and heat mapping</li>
            <li>Managed homepage experience including high-profile Universal Studios partnership</li>
            <li>Optimized checkout flows to increase conversion rates</li>
          </ul>
        </div>

        <!-- Earlier Experience -->
        <div class="relative pl-8 border-l-2 border-zinc-600">
          <div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-zinc-600"></div>
          <div class="mb-3">
            <h3 class="text-xl font-semibold text-gray-100">Earlier Roles</h3>
            <p class="text-gray-400 text-sm">2006 - 2015</p>
          </div>
          <p class="text-gray-300 leading-relaxed">
            Prior experience includes positions at HomeSmart, Simple Sites, Xhibit Corp, and Zion & Zion, where I designed interactive museum exhibits, <span class="whitespace-nowrap">e-commerce</span> platforms, and digital marketing campaigns for clients like General Motors, Arizona Science Center, and Sotheby's.
          </p>
        </div>
      </div>
      </div>
    </div>
  </section>

  <!-- Skills & Expertise -->
  <section class="container-custom py-20">
    <h2 class="text-sm font-semibold text-gray-100 uppercase tracking-wider mb-12">
      Skills & Expertise
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div>
        <h3 class="text-xl font-semibold text-gray-100 mb-6">Design</h3>
        <ul class="space-y-3 text-gray-300">
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-2 text-gray-100 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            UX/UI Design
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-2 text-gray-100 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Atomic Design Systems
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-2 text-gray-100 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            User Research
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-2 text-gray-100 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            A/B Testing
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-2 text-gray-100 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            AI-Enhanced Workflows
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-gray-100 mb-6">Development</h3>
        <ul class="space-y-3 text-gray-300">
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-2 text-gray-100 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            React & Angular
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-2 text-gray-100 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Component Architecture
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-2 text-gray-100 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Responsive Design
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-2 text-gray-100 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Accessibility (WCAG)
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-2 text-gray-100 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Performance Optimization
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-gray-100 mb-6">Strategy</h3>
        <ul class="space-y-3 text-gray-300">
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-2 text-gray-100 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Digital Marketing
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-2 text-gray-100 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="whitespace-nowrap">E-commerce</span> Optimization
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-2 text-gray-100 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Analytics & ROI
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-2 text-gray-100 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Team Leadership
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-2 text-gray-100 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Cross-functional Collaboration
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="container-custom py-20">
    <h2 class="text-sm font-semibold text-gray-100 uppercase tracking-wider mb-12">
      What People Say
    </h2>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Testimonial 1: Roxana Epps -->
      <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-8 flex flex-col">
