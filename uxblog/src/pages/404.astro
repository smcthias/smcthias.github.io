---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Savelle McThias"
  description="The page you're looking for doesn't exist. Explore UX design case studies or learn more about Savelle McThias's design work."
>
  <section class="container-custom py-32 text-center">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-9xl font-bold text-zinc-800 mb-4">404</h1>
      <h2 class="text-4xl font-bold text-gray-100 mb-6">Page Not Found</h2>
      <p class="text-xl text-gray-400 mb-10">
        Sorry, the page you're looking for doesn't exist or has been moved.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-flex items-center px-6 py-3 bg-gray-100 text-gray-900 text-base font-medium rounded-full hover:bg-gray-200 transition-colors"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Go Home
        </a>
        <a
          href="/work"
          class="inline-flex items-center px-6 py-3 border-2 border-zinc-700 text-gray-100 text-base font-medium rounded-full hover:bg-zinc-900 transition-colors"
        >
          View My Work
        </a>
      </div>

      <div class="mt-16 pt-16 border-t border-zinc-800">
        <h3 class="text-sm font-semibold text-gray-100 uppercase tracking-wider mb-6">
          Popular Pages
        </h3>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="/about" class="text-sm text-gray-400 hover:text-gray-100 transition-colors">About</a>
          <a href="/work" class="text-sm text-gray-400 hover:text-gray-100 transition-colors">Work</a>
          <a href="/contact" class="text-sm text-gray-400 hover:text-gray-100 transition-colors">Contact</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
