---
import BaseLayout from '@layouts/BaseLayout.astro';
import { serviceSchema, faqPageSchema, SITE_URL } from '@/lib/schema';

const faqs = [
  {
    question: 'Do you work with startups?',
    answer:
      "Absolutely. I've worked with companies at every stage—from pre-launch startups to public enterprises. The key is having a clear vision and commitment to exceptional user experience.",
  },
  {
    question: "What's your typical project timeline?",
    answer:
      "Most projects range from 4-16 weeks depending on scope. Design systems and enterprise work tend toward the longer end. I'll provide a detailed timeline in your proposal.",
  },
  {
    question: 'Do you offer ongoing support after launch?',
    answer:
      'Yes. I offer post-launch optimization reviews and monthly retainer options for continued partnership.',
  },
  {
    question: 'Can you work with our existing development team?',
    answer:
      "Definitely. I collaborate closely with in-house teams, providing detailed specs, assets, and implementation support. I've worked with teams using React, Angular, Vue, and various other frameworks.",
  },
  {
    question: "What if we're not sure what we need?",
    answer:
      "That's exactly why the discovery phase exists. We'll start with a conversation about your goals and challenges, and I'll recommend the right approach.",
  },
  {
    question: 'Do you sign NDAs?',
    answer: "Yes, I'm happy to sign NDAs and work within your security requirements.",
  },
];

const pageSchema = [
  serviceSchema({
    name: 'UX/UI & Product Design Services',
    serviceType: 'UX/UI and Product Design',
    description:
      'Senior, hands-on UX/UI and product design for SaaS and e-commerce teams — UX research, design systems, e-commerce conversion optimization, enterprise SaaS design, and fractional design leadership.',
    url: `${SITE_URL}/services`,
  }),
  faqPageSchema(faqs),
];
---

<BaseLayout
  title="Design, Development & Branding Services — Savelle McThias"
  description="Web design, branding, logo design, front-end development, and product design. Serving Phoenix and Scottsdale businesses locally, and product teams worldwide remotely."
  schema={pageSchema}
>
  <!-- Hero Section -->
  <section class="relative container-custom pt-32 pb-20 border-b border-zinc-800 overflow-hidden">
    <!-- Web design line art background -->
    <svg
      class="absolute inset-0 w-full h-full pointer-events-none select-none"
      viewBox="0 0 1400 480"
      preserveAspectRatio="xMidYMid slice"
      fill="none"
