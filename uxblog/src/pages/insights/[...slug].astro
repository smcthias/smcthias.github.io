---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { blogPostingSchema, breadcrumbListSchema, SITE_URL } from '@/lib/schema';

export async function getStaticPaths() {
  const posts = (await getCollection('insights')).filter((post) => !post.data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const postUrl = `${SITE_URL}/insights/${post.id}`;
const published = post.data.pubDate.toISOString().slice(0, 10);
const modified = post.data.updatedDate?.toISOString().slice(0, 10);

const dateFormat = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});

const pageSchema = [
  blogPostingSchema({
    headline: post.data.title,
    description: post.data.description,
    url: postUrl,
    datePublished: published,
    dateModified: modified,
    keywords: post.data.tags,
    image: post.data.hero?.src,
  }),
  breadcrumbListSchema([
    { name: 'Home', url: SITE_URL },
    { name: 'Insights', url: `${SITE_URL}/insights` },
    { name: post.data.title, url: postUrl },
  ]),
];
---

<BaseLayout
  title={`${post.data.title} | Savelle McThias`}
  description={post.data.description}
  image={post.data.hero?.src}
  schema={pageSchema}
>
  <Breadcrumbs items={[
    { label: 'Insights', href: '/insights' },
    { label: post.data.title, href: `/insights/${post.id}` },
  ]} />

  <!-- Article header -->
  <article>
    <header class="container-custom pt-16 pb-12">
      <div class="max-w-3xl mx-auto">
        <div class="flex items-center gap-4 text-sm text-gray-500 mb-6">
          <time datetime={published}>{dateFormat.format(post.data.pubDate)}</time>
          {post.data.updatedDate && (
            <span>Updated {dateFormat.format(post.data.updatedDate)}</span>
          )}
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold text-gray-100 tracking-tight leading-[1.1] mb-6 text-balance">
          {post.data.title}
        </h1>
        <p class="text-xl text-gray-400 leading-relaxed text-pretty">
          {post.data.description}
        </p>
      </div>
    </header>

    {post.data.hero && (
      <section class="container-custom pb-12">
        <div class="max-w-4xl mx-auto rounded-2xl overflow-hidden">
          <img src={post.data.hero.src} alt={post.data.hero.alt} class="w-full object-cover" />
        </div>
      </section>
    )}

    <!-- Article body -->
    <section class="container-custom pb-16">
      <div class="max-w-3xl mx-auto prose-custom">
        <Content />
      </div>
    </section>
  </article>

  <!-- Closing CTA -->
  <section class="container-custom pb-16">
    <div class="max-w-3xl mx-auto bg-zinc-900 border border-zinc-800 rounded-3xl p-10 md:p-14 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-100 mb-4 tracking-tight text-balance">
        {post.data.cta?.heading ?? "Ready to make your product clearer?"}
      </h2>
      <p class="text-lg text-gray-300 mb-8 max-w-xl mx-auto text-pretty">
        {post.data.cta?.text ??
          "Tell me what your product should be doing that it isn't — I'll tell you where I'd look first."}
      </p>
      <a
        href={post.data.cta?.href ?? '/contact'}
        class="inline-flex items-center px-8 py-4 bg-gray-100 text-zinc-950 text-base font-medium rounded-full hover:bg-white transition-colors"
      >
        {post.data.cta?.button ?? 'Start a project'}
      </a>
    </div>
  </section>

  <!-- Footer navigation -->
  <section class="container-custom pb-16">
    <div class="max-w-3xl mx-auto flex items-center justify-between border-t border-zinc-800 pt-8">
      <a
        href="/insights"
        class="inline-flex items-center text-gray-400 hover:text-gray-100 transition-colors"
      >
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        All Insights
      </a>
      <a href="/contact" class="text-sm font-medium text-gray-400 hover:text-gray-100 transition-colors">
        Start a project
      </a>
    </div>
  </section>
</BaseLayout>
