---
import { testimonials } from '@/data/testimonials';
---

<section class="container-custom py-20">
  <h2 class="text-sm font-semibold text-gray-100 uppercase tracking-wider mb-12">
    What People Say
  </h2>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    {testimonials.map((t) => (
      <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-8 flex flex-col">
        <div class="mb-6">
          <svg class="w-10 h-10 text-gray-600" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>
        </div>

        <blockquote class="text-gray-300 leading-relaxed mb-6 grow">
          {t.paragraphs.map((p, i) => (
            <p class={i < t.paragraphs.length - 1 || t.italicHtml ? 'mb-4' : ''}>{p}</p>
          ))}
          {t.italicHtml && (
            <p class="text-gray-400 italic text-sm" set:html={t.italicHtml} />
          )}
        </blockquote>

        <div class="flex items-center gap-4 pt-6 border-t border-zinc-700">
          <div class="w-12 h-12 rounded-full bg-zinc-800 flex items-center justify-center">
            <span class="text-lg font-semibold text-gray-100">{t.initials}</span>
          </div>
          <div>
            <div class="font-semibold text-gray-100">{t.name}</div>
            <div class="text-sm text-gray-400">{t.title}, {t.company}</div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
