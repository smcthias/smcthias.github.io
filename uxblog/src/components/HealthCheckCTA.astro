---
// Site-wide promotional band for the free UX Health Check lead magnet.
// Rendered by BaseLayout before the footer on every page except where opted
// out (e.g. the Health Check page itself). Full-bleed zinc-900 band (no
// rounded corners / border) matching the services "What I Do" section.
---

<section class="bg-zinc-900 py-16">
  <div class="container-custom flex flex-col md:flex-row md:items-center gap-8 max-w-4xl mx-auto">
    <div class="max-w-xl">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-widest mb-3">Free Tool · 2 Minutes</p>
      <h2 class="text-2xl md:text-3xl font-display font-bold text-gray-100 mb-2 tracking-tight">
        How healthy is your business website?
      </h2>
      <p class="text-gray-400 leading-relaxed">
        Take the free UX Health Check, built for local businesses, and get an instant score
        across five dimensions — plus three prioritized fixes you can act on this week.
      </p>
    </div>
    <a
      href="/ux-health-check"
      class="inline-flex items-center justify-center whitespace-nowrap px-6 py-3 bg-gray-100 text-zinc-950 text-base font-medium rounded-full hover:bg-white transition-colors shrink-0 group"
    >
      Get your free check
      <svg class="ml-2 w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</section>
