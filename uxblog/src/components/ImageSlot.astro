---
interface Props {
  label: string;
  hint?: string;
  aspect?: 'video' | 'square' | 'wide' | 'auto';
  class?: string;
  src?: string;
}
const { label, hint, aspect = 'video', class: className, src } = Astro.props;
const aspectClass = {
  video: 'aspect-video',
  square: 'aspect-square',
  wide: 'aspect-[21/9]',
  auto: 'min-h-64',
}[aspect];
const margin = className !== undefined ? className : 'my-12';
---

{src ? (
  <div class={`${aspectClass} w-full rounded-2xl overflow-hidden ${margin}`}>
    <img src={src} alt={label} class="w-full h-full object-cover" />
  </div>
) : (
  <div class={`${aspectClass} w-full bg-zinc-900 border border-dashed border-zinc-700 rounded-2xl flex flex-col items-center justify-center ${margin} px-8 text-center gap-3`}>
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-widest">{label}</p>
    {hint && <p class="text-gray-600 text-sm max-w-lg leading-relaxed">{hint}</p>}
  </div>
)}
