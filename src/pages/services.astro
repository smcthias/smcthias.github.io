---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const services = [
  {
    title: 'Landing Page Design',
    description: 'Create high-converting landing pages that turn visitors into customers.',
    icon: '<svg class="w-full h-full" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/></svg>',
    details: [
      'Custom design tailored to your campaign goals',
      'Mobile-first responsive design',
      'Clear call-to-action placement',
      'Fast loading speed optimization',
      'SEO-friendly code and structure',
      'Analytics integration and tracking'
    ],
    slug: 'landing-page-design'
  },
  {
    title: 'Website Refresh & Redesign',
    description: 'Modernize your website with a fresh design that better represents your brand.',
    icon: '<svg class="w-full h-full" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>',
    details: [
      'Website audit and recommendations',
      'Modern, contemporary design',
      'Improved navigation and structure',
      'Mobile optimization',
      'Performance improvements',
      'Content strategy guidance'
    ],
    slug: 'website-refresh'
  },
  {
    title: 'Brand Identity Touchups',
    description: 'Refine your brand identity to create a consistent, professional look.',
    icon: '<svg class="w-full h-full" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>',
    details: [
      'Logo refinement and variations',
      'Color palette optimization',
      'Typography selection',
      'Simple brand guidelines',
      'Marketing templates',
      'File delivery for print and digital'
    ],
    slug: 'brand-identity'
  },
  {
    title: 'Email Campaign Design',
    description: 'Design engaging email campaigns that connect with your audience and drive results.',
    icon: '<svg class="w-full h-full" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>',
    details: [
      'Custom email template design',
      'Campaign strategy and planning',
      'Mobile-responsive layouts',
      'Series design (welcome, nurture, promotional)',
      'Clear call-to-actions',
      'Platform integration support'
    ],
    slug: 'email-campaigns'
  }
];
---

<Layout title="Services - Savelle Design" description="Design services including landing pages, website refresh, brand identity, and email campaigns for growing businesses.">
    <!-- Hero Section -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold text-zinc-900 mb-6">Services</h1>
      <p class="text-xl text-zinc-600 max-w-3xl mb-6">
        I help growing businesses create professional design that connects with customers and drives results. From landing pages to brand touchups, I focus on practical solutions that make a real difference.
      </p>
      <a
        href={`${base}/pricing`}
        class="inline-flex items-center text-zinc-900 font-medium hover:text-zinc-600 transition-colors"
      >
        View pricing
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
      </div>
    </section>

    <!-- Services List -->
    <section class="py-20 bg-zinc-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="space-y-16">
        {services.map((service, index) => (
          <div class="border-t border-zinc-200 pt-16 first:border-t-0 first:pt-0">
            <div class="grid md:grid-cols-2 gap-12">
              <div>
                <div class="flex items-center gap-4 mb-6">
                  <div class="w-12 h-12 text-zinc-900" set:html={service.icon}></div>
                  <div class="text-sm font-semibold text-zinc-500">
                    0{index + 1}
                  </div>
                </div>
                <h2 class="text-3xl font-bold text-zinc-900 mb-4">
                  <a href={`${base}/services/${service.slug}`} class="hover:text-zinc-600 transition-colors">
                    {service.title}
                  </a>
                </h2>
                <p class="text-lg text-zinc-600 mb-6">
                  {service.description}
                </p>
                <a
                  href={`${base}/services/${service.slug}`}
                  class="inline-flex items-center text-zinc-900 font-medium hover:text-zinc-600 transition-colors"
                >
                  Learn more
                  <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-zinc-900 mb-4">What's included:</h3>
                <ul class="space-y-3">
                  {service.details.map(detail => (
                    <li class="flex items-start">
                      <svg class="w-5 h-5 text-zinc-900 mr-3 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class="text-zinc-600">{detail}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
        </div>
      </div>
    </section>

    <!-- Process Section -->
    <section class="py-20 bg-zinc-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-12">How I Work</h2>
        <div class="grid md:grid-cols-4 gap-8">
          <div>
            <div class="w-12 h-12 bg-white text-zinc-900 rounded-lg flex items-center justify-center text-xl font-bold mb-4">
              1
            </div>
            <h3 class="text-xl font-semibold text-white mb-2">Discovery</h3>
            <p class="text-zinc-300">
              Understanding your goals, audience, and project requirements.
            </p>
          </div>
          <div>
            <div class="w-12 h-12 bg-white text-zinc-900 rounded-lg flex items-center justify-center text-xl font-bold mb-4">
              2
            </div>
            <h3 class="text-xl font-semibold text-white mb-2">Design</h3>
            <p class="text-zinc-300">
              Creating mockups and prototypes based on research and best practices.
            </p>
          </div>
          <div>
            <div class="w-12 h-12 bg-white text-zinc-900 rounded-lg flex items-center justify-center text-xl font-bold mb-4">
              3
            </div>
            <h3 class="text-xl font-semibold text-white mb-2">Development</h3>
            <p class="text-zinc-300">
              Building with clean code and modern technologies for optimal performance.
            </p>
          </div>
          <div>
            <div class="w-12 h-12 bg-white text-zinc-900 rounded-lg flex items-center justify-center text-xl font-bold mb-4">
              4
            </div>
            <h3 class="text-xl font-semibold text-white mb-2">Launch</h3>
            <p class="text-zinc-300">
              Testing, refining, and deploying your project with ongoing support.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-zinc-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
            Ready to get started?
          </h2>
          <p class="text-xl text-zinc-300 mb-8">
            Let's discuss your project and see how I can help you achieve your goals.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href={`${base}/contact`}
              class="inline-block px-8 py-3 bg-white text-zinc-900 rounded-lg hover:bg-zinc-100 transition-colors font-medium"
            >
              Contact Me
            </a>
            <a
              href={`${base}/pricing`}
              class="inline-block px-8 py-3 border-2 border-zinc-700 text-white rounded-lg hover:bg-zinc-800 transition-colors font-medium"
            >
              View Pricing
            </a>
          </div>
        </div>
      </div>
    </section>
</Layout>
