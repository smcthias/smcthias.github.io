---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = (Astro.site || 'https://savelledesign.com').toString().replace(/\/$/, '');

// FAQ schema is derived from the on-page Q&As below — keep the two in sync.
const faqs = [
  {
    question: "What's the difference between a refresh and a full rebuild?",
    answer:
      "A refresh keeps what's working — your structure, content, and platform — and modernizes the look, the layout, and the parts that frustrate visitors. A rebuild starts over. Most businesses need a refresh, not a teardown; we'll figure out which on the first call.",
  },
  {
    question: 'Will a redesign hurt my Google rankings?',
    answer:
      'Not when it is done carefully. I preserve your URLs, keep your content intact, and set up redirects for anything that moves, so the search equity you have built comes with you. A good redesign helps findability — it does not reset it.',
  },
  {
    question: 'Can you work with my existing website platform?',
    answer:
      "Usually, yes — WordPress, Squarespace, Webflow, Shopify, and most common setups. If your current platform is holding you back, I'll tell you plainly and lay out the tradeoffs before you commit to a move.",
  },
  {
    question: 'How do I know my site actually needs work?',
    answer:
      'Take the free UX Health Check — ten questions, an instant score, and your three highest-priority fixes. If you want a hands-on review of a live site, the 48-Hour UX Audit pinpoints what is costing you conversions.',
  },
  {
    question: 'How much does a website refresh cost?',
    answer:
      'It comes down to how many pages change and how much new design and content is involved. Ranges are on the pricing page, and we agree on a fixed scope and price before I start.',
  },
];

const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Website Refresh & Redesign',
    serviceType: 'Website Redesign',
    description:
      'A website redesign that modernizes structure, visuals, and content while preserving the search equity you have already built.',
    url: `${siteUrl}/services/website-refresh`,
    provider: { '@type': 'Person', name: 'Savelle McThias' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  },
];
---

<Layout title="Website Refresh & Redesign - Savelle Design" description="Modernize your website with a fresh design that better represents your brand and engages your audience.">
    <!-- Hero Section -->
    <section class="py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href={`${base}/services`} class="inline-flex items-center text-zinc-600 hover:text-zinc-900 transition-colors mb-8">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Services
      </a>
      <h1 class="text-4xl md:text-6xl font-bold text-zinc-900 mb-6">Website Refresh & Redesign</h1>
      <p class="text-xl md:text-2xl text-zinc-600 max-w-3xl mb-6">
        Give your website a modern makeover that better represents your brand, improves user experience, and drives more business results.
      </p>
      <a href={`${base}/pricing`} class="inline-flex items-center text-zinc-900 font-medium hover:text-zinc-600 transition-colors">
        View pricing
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
      </div>
    </section>

    <!-- Service Overview -->
    <section class="py-12 border-t border-zinc-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-3xl font-bold text-zinc-900 mb-6">Why Refresh Your Website?</h2>
          <p class="text-lg text-zinc-600 mb-6">
            Your website is often the first place potential customers learn about your business. If it looks outdated, is hard to use, or doesn't work well on mobile devices, you could be losing opportunities.
          </p>
          <p class="text-lg text-zinc-600">
            A website refresh can improve your brand perception, make it easier for customers to find what they need, and ultimately grow your business—all without starting from scratch.
          </p>
        </div>
        <div class="aspect-[4/3] rounded-lg overflow-hidden">
          <img src={`${base}/images/works/nikkl-detail3.png`} alt="Website Refresh and Redesign Example" class="w-full h-full object-cover" />
        </div>
      </div>
      </div>
    </section>

    <!-- What's Included -->
    <section class="py-12 bg-zinc-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-zinc-900 mb-8">What's Included</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 bg-white border border-zinc-200 rounded-lg">
          <h3 class="text-xl font-semibold text-zinc-900 mb-3">Website Audit</h3>
          <p class="text-zinc-600">
            I'll review your current site to identify what's working and what needs improvement.
          </p>
        </div>
        <div class="p-6 bg-white border border-zinc-200 rounded-lg">
          <h3 class="text-xl font-semibold text-zinc-900 mb-3">Modern Design</h3>
          <p class="text-zinc-600">
            A fresh, contemporary look that aligns with current design trends and your brand.
          </p>
        </div>
        <div class="p-6 bg-white border border-zinc-200 rounded-lg">
          <h3 class="text-xl font-semibold text-zinc-900 mb-3">Improved Navigation</h3>
          <p class="text-zinc-600">
            Reorganize and simplify your site structure so visitors can find what they need quickly.
          </p>
        </div>
        <div class="p-6 bg-white border border-zinc-200 rounded-lg">
          <h3 class="text-xl font-semibold text-zinc-900 mb-3">Mobile Optimization</h3>
          <p class="text-zinc-600">
            Ensure your site looks great and functions perfectly on smartphones and tablets.
          </p>
        </div>
        <div class="p-6 bg-white border border-zinc-200 rounded-lg">
          <h3 class="text-xl font-semibold text-zinc-900 mb-3">Performance Boost</h3>
          <p class="text-zinc-600">
            Speed up loading times to keep visitors engaged and improve search rankings.
          </p>
        </div>
        <div class="p-6 bg-white border border-zinc-200 rounded-lg">
          <h3 class="text-xl font-semibold text-zinc-900 mb-3">Content Strategy</h3>
          <p class="text-zinc-600">
            Guidance on updating your messaging to better connect with your audience.
          </p>
        </div>
      </div>
      </div>
    </section>

    <!-- Perfect For -->
    <section class="py-12 bg-zinc-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-white mb-8">Perfect For</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div>
          <h3 class="text-xl font-semibold text-white mb-3">Growing Businesses</h3>
          <p class="text-zinc-300">
            Your business has evolved, and your website should reflect your growth and new offerings.
          </p>
        </div>
        <div>
          <h3 class="text-xl font-semibold text-white mb-3">Dated Websites</h3>
          <p class="text-zinc-300">
            Your site was built years ago and looks outdated compared to competitors.
          </p>
        </div>
        <div>
          <h3 class="text-xl font-semibold text-white mb-3">Poor Performance</h3>
          <p class="text-zinc-300">
            Your current site is slow, hard to use, or doesn't work well on mobile devices.
          </p>
        </div>
      </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-zinc-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl md:text-4xl font-bold text-zinc-900 mb-12 text-center">Frequently Asked Questions</h2>
        <div class="max-w-3xl mx-auto space-y-4">
          {faqs.map((f) => (
            <div class="p-6 bg-white border border-zinc-200 rounded-lg">
              <h3 class="text-lg font-semibold text-zinc-900 mb-2">{f.question}</h3>
              <p class="text-zinc-600">{f.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-zinc-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
            Ready to give your website a fresh look?
          </h2>
          <p class="text-xl text-zinc-300 mb-8">
            Let's discuss how a website refresh can help your business grow and better serve your customers.
          </p>
          <a
            href={`${base}/contact`}
            class="inline-block px-8 py-3 bg-white text-zinc-900 rounded-lg hover:bg-zinc-100 transition-colors font-medium"
          >
            Let's Talk
          </a>
        </div>
      </div>
    </section>

  <!-- Structured Data -->
  {pageSchema.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
</Layout>
