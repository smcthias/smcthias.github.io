---
import { getCollection } from 'astro:content';

const GTM_ID = 'GTM-5CKC7W8X';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://savelledesign.com');
const ogImage = new URL('/images/og-default.jpg', Astro.site || 'https://savelledesign.com');

const title = 'Savelle Design | Senior Product Designer & Creative Director in Scottsdale, AZ';
const description =
  '18 years of product design and creative direction for brands like PetSmart, General Motors, and Sotheby’s, now available directly. Websites, brand identity, UX audits, and overflow design capacity for agencies.';

// Contact form posts to the same Google Apps Script sheet as /contact and
// /ux-health-check (form_type distinguishes rows).
const FORM_ENDPOINT =
  'https://script.google.com/macros/s/AKfycbxg4JxjE1jK4HHB19KOuXcHyNZT37dKvmwN0e8wz-ufeosZEeGMnT774Uk9rLjah3TW/exec';

const VIMEO_ID = '1193063245';

// Curated to five. Copy is hand-written here; images and outcome stats come
// from the projects collection so they stay in sync with the case study pages.
const allProjects = await getCollection('projects');
const pick = (slug: string) => {
  const entry = allProjects.find((p) => p.slug === slug);
  if (!entry) throw new Error(`Missing project for homepage case study: ${slug}`);
  return entry;
};

const caseStudies = [
  {
    entry: pick('lamesa'),
    client: 'La Mesa RV & Van Up',
    discipline: 'E-commerce design & build',
    problem:
      'Eleven dealership locations, thousands of vehicles, and customers who could not find any of them. The sales team was fighting the inventory system as hard as the shoppers were.',
    approach:
      'I designed a search and filter experience built around how people actually shop for RVs, then designed and built Van Up’s e-commerce site from scratch: upgrade scheduling, accessory upsells, and a tracker that shows customers where their van is in the process.',
    quote: {
      text: 'It felt more like having a co-founder who just happened to be insanely talented at UX. He got in the weeds with us, understood our sales team’s pain points, and built something that made everyone’s life easier. That’s rare.',
      name: 'Brian Fidler',
      role: 'Former Head of Marketing, La Mesa RV & Van Up',
    },
  },
  {
    entry: pick('young-living'),
    client: 'Young Living',
    discipline: 'Content platform design',
    problem:
      'Six million brand partners around the world and no single place to send them for product education, promotions, or company news.',
    approach:
      'I designed Grow News from wireframe to launch: a promotion and education hub that matched a brand its audience already loved, structured so a massive distributor network could actually navigate it.',
    quote: null,
  },
  {
    entry: pick('yoli'),
    client: 'Yoli',
    discipline: 'Email design system',
    problem:
      'A wellness brand selling in four countries with email doing the heavy lifting and no system behind it. Every send was a one-off.',
    approach:
      'I built an email design system in Klaviyo, then the campaigns on top of it: onboarding, transactional, and promotional flows, plus the landing pages they pointed to.',
    quote: null,
  },
  {
    entry: pick('nikkl'),
    client: 'Nikkl',
    discipline: 'Brand & website, 5-day sprint',
    problem:
      'A fintech startup helping unicorn employees unlock their stock options needed to look credible to a skeptical audience. And it needed to happen in five days.',
    approach:
      'I rebuilt the logo and color system, illustrated the complicated finance parts so a human could follow them, and designed and developed the site. Concept to launch inside the deadline.',
    quote: null,
  },
  {
    entry: pick('adorned'),
    client: 'Adorned',
    discipline: 'Brand identity',
    problem:
      'An augmented reality mobile game heading into investor pitches with genuinely novel tech and no visual identity to point at.',
    approach:
      'I built an investor-ready brand kit that made cutting-edge AR feel approachable instead of alienating, so the pitch could focus on the product.',
    quote: null,
  },
];

const heroClients = ['PetSmart', 'General Motors', 'Sotheby’s', 'Universal', 'bareMinerals', 'Capitol Records'];

const logos = [
  { src: '/images/logos/logo-petsmart.svg', alt: 'PetSmart logo', h: 'h-[26px]' },
  { src: '/images/logos/logo-gm.svg', alt: 'General Motors logo', h: 'h-[34px]' },
  { src: '/images/logos/logo-plexus.svg', alt: 'Plexus Worldwide logo', h: 'h-[30px]' },
  { src: '/images/logos/logo-sothebys.svg', alt: 'Sotheby’s logo', h: 'h-5' },
  { src: '/images/logos/logo-lamesa.svg', alt: 'La Mesa RV logo', h: 'h-[26px]' },
  { src: '/images/logos/logo-universal.svg', alt: 'Universal logo', h: 'h-[34px]' },
  { src: '/images/logos/logo-capitolrecords.svg', alt: 'Capitol Records logo', h: 'h-[34px]' },
  { src: '/images/logos/logo-thebeachboys.svg', alt: 'The Beach Boys logo', h: 'h-[34px]' },
  { src: '/images/logos/logo-bareminerals.svg', alt: 'bareMinerals logo', h: 'h-3' },
  { src: '/images/logos/logo-richdad.svg', alt: 'Rich Dad logo', h: 'h-3' },
  { src: '/images/logos/logo-sanity.svg', alt: 'Sanity logo', h: 'h-5' },
];
const logoRows = [logos.slice(0, 4), logos.slice(4, 7), logos.slice(7)];

const projectTypes = ['Full website', 'Brand identity', 'Agency overflow', 'UX audit', 'Not sure yet'];
const budgets = ['< $10k', '$10–25k', '$25k+', 'Not sure'];

const chapters = [
  { id: 'reel', n: '01', label: 'Reel' },
  { id: 'work', n: '02', label: 'Work' },
  { id: 'check', n: '03', label: 'Checkup' },
  { id: 'capacity', n: '04', label: 'Capacity' },
  { id: 'about', n: '05', label: 'About' },
  { id: 'contact', n: '06', label: 'Contact' },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': 'https://savelledesign.com/#savelle',
      name: 'Savelle McThias',
      jobTitle: 'Senior Product Designer & Creative Director',
      url: 'https://savelledesign.com',
      sameAs: ['https://www.linkedin.com/in/savelle/'],
      address: { '@type': 'PostalAddress', addressLocality: 'Scottsdale', addressRegion: 'AZ', addressCountry: 'US' },
      knowsAbout: [
        'UX design',
        'UI design',
        'web design',
        'brand identity design',
        'email marketing design',
        'e-commerce design',
        'creative direction',
      ],
    },
    {
      '@type': 'ProfessionalService',
      name: 'Savelle Design',
      url: 'https://savelledesign.com',
      description:
        'Independent product design studio of Savelle McThias: websites, brand identity, UX audits, and overflow design capacity for agencies and marketing teams.',
      founder: { '@id': 'https://savelledesign.com/#savelle' },
      areaServed: 'United States',
      address: { '@type': 'PostalAddress', addressLocality: 'Scottsdale', addressRegion: 'AZ', addressCountry: 'US' },
      makesOffer: [
        { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Website design and development' } },
        { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Brand identity design' } },
        { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'UX audit' } },
        { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Overflow design capacity for agencies' } },
      ],
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google Tag Manager -->
    <script define:vars={{ gtmId: GTM_ID }}>
      window.dataLayer = window.dataLayer || [];
      window.gtag = function gtag() {
        const a = arguments;
        if (a[0] === 'event' && typeof a[1] === 'string') {
          window.dataLayer.push(Object.assign({ event: a[1] }, a[2] || {}));
        } else {
          window.dataLayer.push(a);
        }
      };
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
        const f = d.getElementsByTagName(s)[0];
        const j = d.createElement(s);
        const dl = l !== 'dataLayer' ? '&l=' + l : '';
        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, 'script', 'dataLayer', gtmId);
    </script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Savelle Design" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="author" content="Savelle McThias" />
    <meta name="robots" content="index, follow" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@100,400;100,500;100,600;125,700;125,800;125,900&family=Newsreader:ital,opsz,wght@1,6..72,400..500&family=Spline+Sans+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />
    <script is:inline>document.documentElement.classList.add('js');</script>
  </head>

  <body class="bg-gesso text-ink font-sans antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`}
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->

    <a
      href="#work"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[60] focus:bg-ultra focus:text-white focus:px-4 focus:py-2 focus:rounded"
    >
      Skip to content
    </a>

    <!-- Header -->
    <header class="fixed top-0 inset-x-0 z-50 bg-ink/90 backdrop-blur-sm text-gesso">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between">
        <a href={`${base}/`} class="font-mono text-sm tracking-widest uppercase hover:text-signal transition-colors">
          Savelle Design
        </a>
        <nav aria-label="Primary" class="flex items-center gap-6">
          <a href="#work" class="hidden md:inline font-mono text-xs tracking-widest uppercase text-putty hover:text-gesso transition-colors">Work</a>
          <a href="#check" class="hidden md:inline font-mono text-xs tracking-widest uppercase text-putty hover:text-gesso transition-colors">UX Check</a>
          <a href="#capacity" class="hidden md:inline font-mono text-xs tracking-widest uppercase text-putty hover:text-gesso transition-colors">Agencies</a>
          <a
            href="#contact"
            class="inline-flex items-center px-4 py-1.5 bg-ultra text-white font-mono text-xs tracking-widest uppercase rounded hover:bg-signal hover:text-ink transition-colors"
          >
            Start a project
          </a>
        </nav>
      </div>
    </header>

    <!-- Chapter rail (desktop) -->
    <nav id="rail" aria-label="Page sections" class="hidden xl:flex fixed left-6 top-1/2 -translate-y-1/2 z-40 flex-col gap-3">
      {chapters.map((c) => (
        <a
          href={`#${c.id}`}
          data-rail={c.id}
          class="rail-link font-mono text-[11px] tracking-[0.2em] uppercase transition-colors"
        >
          {c.n} {c.label}
        </a>
      ))}
    </nav>

    <main>
      <!-- ============ 01 · HERO / THE REEL (dark) ============ -->
      <section id="reel" data-theme="dark" class="bg-ink text-gesso relative overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-16 md:pt-40 md:pb-20 min-h-[92svh] flex flex-col justify-center">
          <div class="grid lg:grid-cols-12 gap-12 lg:gap-8 items-center">
            <div class="lg:col-span-7">
              <p class="rv font-mono text-xs tracking-[0.25em] uppercase text-putty mb-6" style="--d:0ms">
                Scottsdale, Arizona &middot; Est. 18 years in
              </p>
              <h1 class="rv wide text-4xl sm:text-5xl md:text-6xl xl:text-7xl font-extrabold leading-[1.02] mb-6" style="--d:80ms">
                Enterprise-grade design.<br />
                <span class="text-signal">No agency in the way.</span>
              </h1>
              <p class="rv text-lg md:text-xl text-gesso/80 leading-relaxed max-w-xl mb-8" style="--d:160ms">
                I&rsquo;m Savelle McThias, a senior product designer and creative director. For 18 years I&rsquo;ve
                designed for brands like PetSmart, General Motors, and Sotheby&rsquo;s. Now you work with me
                directly: you email me, I reply, I do the work.
              </p>
              <div class="rv flex flex-wrap gap-4 mb-10" style="--d:240ms">
                <a
                  href="#work"
                  class="inline-flex items-center px-7 py-3 bg-ultra text-white font-medium rounded hover:bg-signal hover:text-ink transition-colors"
                >
                  See the work
                </a>
                <a
                  href="#contact"
                  class="inline-flex items-center px-7 py-3 border border-putty/50 text-gesso font-medium rounded hover:border-gesso hover:bg-gesso/5 transition-colors"
                >
                  Start a project
                </a>
              </div>
              <p class="rv font-mono text-[11px] tracking-[0.18em] uppercase text-putty/80" style="--d:320ms">
                {heroClients.join(' · ')}
              </p>
            </div>

            <!-- The Screening: reel poster frame -->
            <div class="lg:col-span-5 rv" style="--d:200ms">
              <div id="reel-frame" class="relative aspect-video bg-[#1A1E25] border border-putty/25 rounded overflow-hidden">
                <!-- corner registration marks -->
                <span class="absolute top-2 left-2 w-4 h-4 border-t border-l border-putty/50" aria-hidden="true"></span>
                <span class="absolute top-2 right-2 w-4 h-4 border-t border-r border-putty/50" aria-hidden="true"></span>
                <span class="absolute bottom-2 left-2 w-4 h-4 border-b border-l border-putty/50" aria-hidden="true"></span>
                <span class="absolute bottom-2 right-2 w-4 h-4 border-b border-r border-putty/50" aria-hidden="true"></span>

                <button
                  type="button"
                  id="reel-play"
                  class="group absolute inset-0 w-full h-full flex flex-col items-center justify-center gap-3 cursor-pointer"
                  aria-label="Play the 2026 design reel (loads Vimeo player)"
                >
                  <span class="relative inline-flex items-center justify-center" aria-hidden="true">
                    <svg viewBox="0 0 120 120" class="w-28 h-28 md:w-32 md:h-32">
                      <circle cx="60" cy="60" r="54" fill="none" stroke="#2B3FDE" stroke-width="1.5" opacity="0.45"></circle>
                      <circle
                        class="ring-draw"
                        cx="60"
                        cy="60"
                        r="54"
                        fill="none"
                        stroke="#E3A32F"
                        stroke-width="2"
                        transform="rotate(-90 60 60)"
                        stroke-linecap="round"></circle>
                      <line x1="60" y1="2" x2="60" y2="12" stroke="#A79F8D" stroke-width="1"></line>
                      <line x1="60" y1="108" x2="60" y2="118" stroke="#A79F8D" stroke-width="1"></line>
                      <line x1="2" y1="60" x2="12" y2="60" stroke="#A79F8D" stroke-width="1"></line>
                      <line x1="108" y1="60" x2="118" y2="60" stroke="#A79F8D" stroke-width="1"></line>
                    </svg>
                    <span class="absolute inset-0 flex items-center justify-center wide text-3xl md:text-4xl font-extrabold text-gesso">
                      18
                    </span>
                  </span>
                  <span class="font-mono text-[11px] tracking-[0.25em] uppercase text-putty group-hover:text-signal transition-colors">
                    The 2026 reel &middot; Play &#9654;
                  </span>
                </button>
              </div>
              <p class="mt-3 font-serifa italic text-putty text-base">
                Eighteen years, cut down to the good parts.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ============ 02 · SELECTED WORK (light) ============ -->
      <section id="work" data-theme="light" class="bg-gesso py-24 md:py-32">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="max-w-3xl mb-16 md:mb-24">
            <p class="rv font-mono text-xs tracking-[0.25em] uppercase text-ultra mb-4">02 &middot; Selected work</p>
            <h2 class="rv wide text-3xl md:text-5xl font-extrabold text-ink mb-5">Five projects, told properly.</h2>
            <p class="rv text-lg text-graphite leading-relaxed">
              Problem, approach, outcome. Real numbers where clients let me share them.
              No infinite grid of screenshots.
            </p>
          </div>

          <div class="space-y-24 md:space-y-32">
            {caseStudies.map((cs, i) => (
              <article class="rv grid lg:grid-cols-12 gap-8 lg:gap-14 items-start">
                <figure class={`lg:col-span-7 ${i % 2 === 1 ? 'lg:order-2' : ''}`}>
                  <img
                    src={`${base}/images/works/${cs.entry.data.images.hero}`}
                    alt={`${cs.client}: ${cs.discipline} by Savelle McThias`}
                    class="w-full aspect-[16/10] object-cover rounded border border-ink/10"
                    loading={i === 0 ? 'eager' : 'lazy'}
                  />
                </figure>
                <div class={`lg:col-span-5 ${i % 2 === 1 ? 'lg:order-1' : ''}`}>
                  <p class="font-mono text-xs tracking-[0.2em] uppercase text-ultra mb-2">
                    0{i + 1} / {cs.discipline}
                  </p>
                  <h3 class="wide text-2xl md:text-3xl font-extrabold text-ink mb-6">{cs.client}</h3>

                  <p class="font-mono text-[11px] tracking-[0.2em] uppercase text-graphite/60 mb-1.5">Problem</p>
                  <p class="text-graphite leading-relaxed mb-5">{cs.problem}</p>

                  <p class="font-mono text-[11px] tracking-[0.2em] uppercase text-graphite/60 mb-1.5">Approach</p>
                  <p class="text-graphite leading-relaxed mb-6">{cs.approach}</p>

                  <p class="font-mono text-[11px] tracking-[0.2em] uppercase text-graphite/60 mb-3">Outcome</p>
                  <dl class="flex flex-wrap gap-x-8 gap-y-3 mb-7">
                    {cs.entry.data.results.map((r: { value: string; label: string }) => (
                      <div>
                        <dt class="sr-only">{r.label}</dt>
                        <dd>
                          <span class="wide block text-2xl font-extrabold text-ultra">{r.value}</span>
                          <span class="block text-xs text-graphite max-w-[180px]">{r.label}</span>
                        </dd>
                      </div>
                    ))}
                  </dl>

                  <a
                    href={`${base}/works/${cs.entry.slug}`}
                    class="inline-flex items-center gap-2 font-medium text-ink underline underline-offset-4 decoration-ultra decoration-2 hover:text-ultra transition-colors"
                  >
                    Read the full case study <span aria-hidden="true">&rarr;</span>
                  </a>

                  {cs.quote && (
                    <blockquote class="mt-8 border-l-2 border-signal pl-5">
                      <p class="font-serifa italic text-lg text-ink leading-relaxed mb-2">&ldquo;{cs.quote.text}&rdquo;</p>
                      <footer class="font-mono text-[11px] tracking-[0.15em] uppercase text-graphite/70">
                        {cs.quote.name} &middot; {cs.quote.role}
                      </footer>
                    </blockquote>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- ============ 03 · UX HEALTH CHECK (ultramarine panel) ============ -->
      <section id="check" data-theme="light" class="bg-gesso pb-24 md:pb-32">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="rv bg-ultra text-gesso rounded-lg p-8 md:p-14 lg:p-16 grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
            <div>
              <p class="font-mono text-xs tracking-[0.25em] uppercase text-signal mb-4">03 &middot; Free diagnostic</p>
              <h2 class="wide text-3xl md:text-4xl font-extrabold mb-5">How healthy is your website, really?</h2>
              <p class="text-gesso/85 text-lg leading-relaxed mb-4">
                Ten questions, about three minutes, no meeting and no pitch. You get a scored report on
                the spot with the problems ranked by what&rsquo;s likely costing you the most.
              </p>
              <p class="text-gesso/85 text-lg leading-relaxed mb-8">
                Then it&rsquo;s your call: fix things yourself, or ask me. Either way you leave knowing more
                than you arrived with.
              </p>
              <a
                href={`${base}/ux-health-check`}
                class="inline-flex items-center px-7 py-3 bg-gesso text-ink font-medium rounded hover:bg-signal transition-colors"
              >
                Take the free UX Health Check
              </a>
              <p class="mt-6 font-mono text-[11px] tracking-[0.15em] uppercase text-gesso/60">
                savelledesign.com/ux-health-check &middot; forward it to whoever owns the website
              </p>
            </div>

            <!-- sample report card -->
            <div aria-hidden="true" class="bg-ink/20 border border-gesso/20 rounded p-6 md:p-8">
              <p class="font-mono text-[11px] tracking-[0.2em] uppercase text-gesso/70 mb-5">Sample report</p>
              <ul class="space-y-4">
                {[
                  { label: 'First impression', score: 8 },
                  { label: 'Clarity of offer', score: 5 },
                  { label: 'Calls to action', score: 4 },
                  { label: 'Mobile experience', score: 7 },
                  { label: 'Trust signals', score: 6 },
                ].map((row) => (
                  <li>
                    <div class="flex justify-between font-mono text-xs text-gesso/85 mb-1.5">
                      <span>{row.label}</span>
                      <span>{row.score}/10</span>
                    </div>
                    <div class="h-1.5 bg-gesso/15 rounded-full overflow-hidden">
                      <div class="h-full bg-signal rounded-full" style={`width: ${row.score * 10}%`}></div>
                    </div>
                  </li>
                ))}
              </ul>
              <p class="mt-6 font-serifa italic text-gesso/70 text-sm">
                If the score is ugly, at least now you know.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ============ 04 · AGENCY CAPACITY (dark) ============ -->
      <section id="capacity" data-theme="dark" class="bg-ink text-gesso py-24 md:py-32">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="max-w-3xl">
            <p class="rv font-mono text-xs tracking-[0.25em] uppercase text-signal mb-4">
              04 &middot; For agencies and marketing teams
            </p>
            <h2 class="rv wide text-3xl md:text-5xl font-extrabold mb-6">
              Overflow capacity that doesn&rsquo;t need babysitting.
            </h2>
            <p class="rv text-lg text-gesso/80 leading-relaxed mb-4">
              If you run an agency or a marketing team, you know the shape of this problem: more design
              work than designers, and no time to onboard a freelancer who needs a month of context.
            </p>
            <p class="rv text-lg text-gesso/80 leading-relaxed mb-10">
              I plug into your process, your Figma, your PM tool, your standup if you want, and produce
              senior work under your flag. White label is fine. Deadlines get met. You look good to your
              client, which is the entire point.
            </p>
          </div>

