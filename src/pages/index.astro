    <style is:global>
      html {
        scroll-padding-top: 4.5rem;
      }
      @media (prefers-reduced-motion: no-preference) {
        html {
          scroll-behavior: smooth;
        }
      }

      /* Wide display setting for Archivo's width axis */
      .wide {
        font-stretch: 125%;
        letter-spacing: -0.01em;
      }

      /* Visible keyboard focus, site-wide */
      :focus-visible {
        outline: 3px solid #2b3fde;
        outline-offset: 3px;
        border-radius: 2px;
      }
      [data-theme='dark'] :focus-visible,
      header :focus-visible,
      footer :focus-visible {
        outline-color: #e3a32f;
      }

      /* Chapter rail states (JS toggles .on-dark as sections scroll past) */
      .rail-link {
        color: rgba(69, 78, 88, 0.55);
      }
      .rail-link:hover {
        color: #14171c;
      }
      .rail-link[aria-current='true'] {
        color: #2b3fde;
      }
      #rail.on-dark .rail-link {
        color: rgba(167, 159, 141, 0.65);
      }
      #rail.on-dark .rail-link:hover {
        color: #f2efe6;
      }
      #rail.on-dark .rail-link[aria-current='true'] {
        color: #e3a32f;
      }

      /* Orchestrated reveals: only when JS is present AND motion is allowed.
         No-JS and reduced-motion users see everything immediately. */
      @media (prefers-reduced-motion: no-preference) {
        html.js .rv {
          opacity: 0;
          transform: translateY(16px);
          transition:
            opacity 0.7s ease,
            transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
          transition-delay: var(--d, 0ms);
        }
        html.js .rv.in {
          opacity: 1;
          transform: none;
        }
        html.js .ring-draw {
          stroke-dasharray: 339.3;
          stroke-dashoffset: 339.3;
          animation: ring-draw 1.5s cubic-bezier(0.65, 0, 0.35, 1) 0.4s forwards;
        }
        @keyframes ring-draw {
          to {
            stroke-dashoffset: 0;
          }
        }
      }
    </style>

    <script define:vars={{ vimeoId: VIMEO_ID }}>
      // ── Scroll reveals ──
      const revealEls = Array.from(document.querySelectorAll('.rv'));
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const en of entries) {
              if (en.isIntersecting) {
                en.target.classList.add('in');
                io.unobserve(en.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
        );
        revealEls.forEach((el) => io.observe(el));
      } else {
        revealEls.forEach((el) => el.classList.add('in'));
      }

      // ── Chapter rail: active section + dark/light adaptation ──
      const rail = document.getElementById('rail');
      if (rail) {
        const links = Array.from(rail.querySelectorAll('[data-rail]'));
        const sections = Array.from(document.querySelectorAll('main section[id]'));
        const railObserver = new IntersectionObserver(
          (entries) => {
            for (const en of entries) {
              if (!en.isIntersecting) continue;
              const id = en.target.id;
              links.forEach((l) => {
                if (l.getAttribute('data-rail') === id) l.setAttribute('aria-current', 'true');
                else l.removeAttribute('aria-current');
              });
              rail.classList.toggle('on-dark', en.target.getAttribute('data-theme') === 'dark');
            }
          },
          { rootMargin: '-45% 0px -45% 0px' }
        );
        sections.forEach((s) => railObserver.observe(s));
      }

      // ── The Screening: swap poster frame for the Vimeo player on demand ──
      const playBtn = document.getElementById('reel-play');
      const frame = document.getElementById('reel-frame');
      if (playBtn && frame) {
        playBtn.addEventListener('click', () => {
          const iframe = document.createElement('iframe');
          iframe.src =
            'https://player.vimeo.com/video/' + vimeoId + '?autoplay=1&title=0&byline=0&portrait=0';
          iframe.allow = 'autoplay; fullscreen; picture-in-picture';
          iframe.allowFullscreen = true;
          iframe.title = 'Savelle Design 2026 reel';
          iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;';
          frame.innerHTML = '';
          frame.appendChild(iframe);
          if (typeof window.gtag === 'function') {
            window.gtag('event', 'reel_play', { location: 'hero' });
          }
        });
      }
    </script>

    <script>
      // ── Contact form (same endpoint + payload shape as the old /contact page) ──
      const formEl = document.getElementById('pf-form') as HTMLFormElement | null;
      if (formEl) {
        // Re-alias after the guard: TS doesn't carry the null-narrowing into
        // the nested function closures below.
        const form: HTMLFormElement = formEl;
        const endpoint = (form.dataset.endpoint || '').trim();
        const submitBtn = document.getElementById('pf-submit') as HTMLButtonElement;
        const submitLabel = document.getElementById('pf-submit-label')!;
        const spinner = document.getElementById('pf-spinner')!;
        const formError = document.getElementById('pf-form-error')!;
        const successEl = document.getElementById('pf-success')!;
        const successName = document.getElementById('pf-success-name')!;

        const params = new URLSearchParams(window.location.search);
        (['utm_source', 'utm_medium', 'utm_campaign', 'utm_content'] as const).forEach((k) => {
          const input = form.querySelector(`input[name="${k}"]`) as HTMLInputElement | null;
          if (input) input.value = params.get(k) || '';
        });

        const emailOk = (v: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim());

        function showFieldError(id: string, show: boolean) {
          const el = form.querySelector(`[data-error-for="${id}"]`);
          el?.classList.toggle('hidden', !show);
        }

        function validate() {
          const name = (form.querySelector('#pf-name') as HTMLInputElement).value.trim();
          const email = (form.querySelector('#pf-email') as HTMLInputElement).value;
          const message = (form.querySelector('#pf-message') as HTMLTextAreaElement).value.trim();
          showFieldError('pf-name', !name);
          showFieldError('pf-email', !emailOk(email));
          showFieldError('pf-message', !message);
          return !!name && emailOk(email) && !!message;
        }

        ['pf-name', 'pf-email', 'pf-message'].forEach((id) => {
          form.querySelector(`#${id}`)?.addEventListener('input', () => showFieldError(id, false));
        });

        function setLoading(on: boolean) {
          submitBtn.disabled = on;
          spinner.classList.toggle('hidden', !on);
          submitLabel.textContent = on ? 'Sending…' : 'Send project inquiry';
        }

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          formError.classList.add('hidden');
          if ((form.querySelector('input[name="_gotcha"]') as HTMLInputElement).value) return;
          if (!validate()) {
            (form.querySelector('[data-error-for]:not(.hidden)') as HTMLElement | null)
              ?.previousElementSibling?.scrollIntoView({ behavior: 'smooth', block: 'center' });
            return;
          }

          const data = Object.fromEntries(new FormData(form).entries());
          delete (data as Record<string, unknown>)._gotcha;
          setLoading(true);

          try {
            if (endpoint) {
              // Google Apps Script doesn't return CORS headers; a resolved
              // no-cors POST means the request was delivered.
              await fetch(endpoint, {
                method: 'POST',
                mode: 'no-cors',
                headers: { 'Content-Type': 'text/plain;charset=utf-8' },
                body: JSON.stringify(data),
              });
            }

            if (typeof (window as any).gtag === 'function') {
              (window as any).gtag('event', 'generate_lead', {
                method: 'contact_form',
                project_type: data.project_type || 'unspecified',
              });
            }

            successName.textContent = data.name ? `, ${String(data.name).split(' ')[0]}` : '';
            form.hidden = true;
            successEl.hidden = false;
            successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
          } catch (_) {
            setLoading(false);
            formError.innerHTML =
              'Something went wrong sending that. Please try again, or email <a class="underline" href="mailto:savellem@gmail.com">savellem@gmail.com</a> directly.';
            formError.classList.remove('hidden');
          }
        });
      }
    </script>
  </body>
