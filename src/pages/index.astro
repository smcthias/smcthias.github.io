---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SectionDivider from '../components/SectionDivider.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Get all projects from content collections and sort by date (newest first), limit to 6
const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 6);

const logos = [
  { src: '/images/logos/logo-petsmart.svg', alt: 'PetSmart', h: 'h-[26px]' },
  { src: '/images/logos/logo-gm.svg', alt: 'GM', h: 'h-[34px]' },
  { src: '/images/logos/logo-plexus.svg', alt: 'Plexus Worldwide', h: 'h-[30px]' },
  { src: '/images/logos/logo-sothebys.svg', alt: "Sotheby's", h: 'h-5' },
  { src: '/images/logos/logo-lamesa.svg', alt: 'La Mesa RV', h: 'h-[26px]' },
  { src: '/images/logos/logo-universal.svg', alt: 'Universal', h: 'h-[34px]' },
  { src: '/images/logos/logo-capitolrecords.svg', alt: 'Capitol Records', h: 'h-[34px]' },
  { src: '/images/logos/logo-thebeachboys.svg', alt: 'The Beach Boys', h: 'h-[34px]' },
  { src: '/images/logos/logo-bareminerals.svg', alt: 'bareMinerals', h: 'h-3' },
  { src: '/images/logos/logo-richdad.svg', alt: 'Rich Dad', h: 'h-3' },
  { src: '/images/logos/logo-sanity.svg', alt: 'Sanity', h: 'h-5' },
];
---

<Layout
  title="Savelle Design - UX/UI Designer & Web Developer in Scottsdale, AZ"
  description="Professional web design and development services for growing businesses. Specializing in landing pages, website refresh, brand identity, and email campaigns. 18+ years experience."
>
    <!-- Hero Section: copy over a "scanline weave" — horizontal strips of
         Savelle's portfolio images animate in and out, periodically aligning
         to construct one project (click it to open the case study), then
         deconstructing. Canvas is decorative-interactive (aria-hidden); all
         projects remain reachable via Featured Work below. lg+ only. -->
    <section>
      <div class="relative">
        <canvas id="hero-weave" class="absolute inset-0 w-full h-full hidden lg:block" aria-hidden="true"></canvas>
        <div
          class="absolute inset-0 hidden lg:block pointer-events-none"
          style="background: linear-gradient(100deg, rgba(255,255,255,0.94) 0%, rgba(255,255,255,0.7) 38%, rgba(255,255,255,0) 60%);"
          aria-hidden="true"
        >
        </div>
        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 lg:pointer-events-none">
          <div class="max-w-2xl">
            <p class="flex items-center gap-3 text-xl md:text-2xl text-zinc-600 mb-4">
              <img
                src={`${base}/images/about/profile.jpg`}
                alt=""
                class="w-12 h-12 rounded-full object-cover border border-zinc-200"
                width="48"
                height="48"
              />
              Hi, I'm Savelle.
            </p>
            <h1 class="text-4xl md:text-6xl font-bold text-zinc-900 mb-6 leading-tight">
              I design websites that turn visitors into customers.
            </h1>
            <p class="text-xl text-zinc-600 mb-8 leading-relaxed">
              A business is a thousand moving pieces — your brand, your products, your customers' questions. For 18+ years I've pulled them together into websites that bring in more calls, bookings, and sales. You work directly with me, start to finish.
            </p>
            <div class="flex flex-wrap gap-4 mb-6">
              <a
                href={`${base}/works`}
                class="pointer-events-auto px-8 py-3 bg-zinc-900 text-white rounded-lg hover:bg-zinc-800 transition-colors font-medium"
              >
                View Projects
              </a>
              <a
                href={`${base}/contact`}
                class="pointer-events-auto px-8 py-3 border-2 border-zinc-900 text-zinc-900 rounded-lg hover:bg-zinc-50 transition-colors font-medium"
              >
                Let's Talk
              </a>
            </div>
            <a
              href={`${base}/ux-health-check`}
              class="pointer-events-auto inline-flex items-center text-zinc-600 hover:text-zinc-900 font-medium underline underline-offset-4 transition-colors"
            >
              Not ready yet? Get your free UX score
            </a>
          </div>
        </div>
      </div>

      <!-- Trusted by -->
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
        <div class="pt-10 border-t border-zinc-200">
          <p class="text-xs font-medium text-zinc-500 uppercase tracking-widest mb-5">Trusted by teams at</p>
          <div class="flex flex-wrap items-center gap-x-8 gap-y-4 lg:justify-between lg:gap-x-4">
            {logos.map(({ src, alt, h }) => (
              <img src={src} alt={alt} class={`${h} w-auto object-contain brightness-0 opacity-40`} />
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Work Section -->
    <section class="py-20 bg-zinc-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-12">Featured Work</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredProjects.map((project) => (
            <a href={`${base}/works/${project.slug}`} class="group block">
              <div class="relative aspect-[4/3] rounded-lg mb-4 overflow-hidden bg-zinc-800" data-sl-hover>
                <img
                  src={`${base}/images/works/${project.data.thumbnail}`}
                  alt={`${project.data.title} - ${project.data.category} project showcase`}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              </div>
              <h3 class="text-lg font-semibold text-white group-hover:text-zinc-300 transition-colors">{project.data.title}</h3>
              <p class="text-sm text-zinc-400">{project.data.category}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Services Preview -->
    <section class="py-20 bg-zinc-50">
