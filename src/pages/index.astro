    <!-- Scanline-weave hero: horizontal strips of portfolio images drift as an
         ambient weave; every few seconds one project's strips align into a
         ragged-edged image (clickable -> case study), holds, then shreds. -->
    <script>
      (() => {
        const base = import.meta.env.BASE_URL.replace(/\/$/, '');
        const canvas = document.getElementById('hero-weave') as HTMLCanvasElement | null;
        if (!canvas) return;
        const desktop = window.matchMedia('(min-width: 1024px)');
        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

        const PROJECTS = [
          { slug: 'lamesa', title: 'La Mesa RV & Van Up', category: 'E-Commerce' },
          { slug: 'nikkl', title: 'Nikkl', category: 'Branding & Web' },
          { slug: 'yoli', title: 'Yoli', category: 'Email Design' },
          { slug: 'young-living', title: 'Young Living', category: 'Web Design' },
          { slug: 'adorned', title: 'Adorned', category: 'Branding' },
          { slug: 'omegas411', title: 'Omegas411', category: 'Web Design' },
        ];

        const AMBIENT_COUNT = 26;
        const IN_STAGGER = 0.03; // s per row
        const IN_DUR = 0.9;
        const HOLD_DUR = 2.6;
        const OUT_DUR = 1.1;
        const GAP_DUR = 0.9;

        const ctx = canvas.getContext('2d')!;
        const container = canvas.parentElement!;
        let W = 0;
        let H = 0;
        let raf = 0;
        let running = false;
        let started = false;

        const rand = (a: number, b: number) => a + Math.random() * (b - a);
        const easeOutCubic = (p: number) => 1 - Math.pow(1 - p, 3);
        const easeInCubic = (p: number) => p * p * p;
        const clamp01 = (p: number) => Math.max(0, Math.min(1, p));

        type Ambient = {
          imgIdx: number;
          srcY: number;
          y: number;
          h: number;
          x: number;
          w: number;
          vx: number;
          life: number;
          maxLife: number;
          alpha: number;
        };

        type Row = {
          ry: number;
          rh: number;
          delayIn: number;
          delayOut: number;
          slideDir: number;
          slideMag: number;
          ragL: number;
          ragR: number;
        };

        const images: HTMLImageElement[] = PROJECTS.map(() => {
          const img = new Image();
          img.decoding = 'async';
          return img;
        });
        let loadedCount = 0;

        const ambients: Ambient[] = [];
        function spawnAmbient(fresh: boolean): Ambient {
          const w = Math.random() < 0.25 ? rand(W * 0.9, W * 1.15) : rand(180, W * 0.6);
          const maxLife = rand(4, 9);
          return {
            imgIdx: Math.floor(Math.random() * images.length),
            srcY: Math.random(),
            y: rand(0, H),
            h: rand(2.5, 9),
            x: rand(-W * 0.15, W - w * 0.4),
            w,
            vx: rand(-14, 14),
            life: fresh ? rand(0, maxLife) : 0,
            maxLife,
            alpha: rand(0.1, 0.32),
          };
        }

        // formation state machine
        let formIdx = 0;
        let phase: 'in' | 'hold' | 'out' | 'gap' = 'gap';
        let phaseStart = 0;
        let region = { x: 0, y: 0, w: 0, h: 0 };
        let rows: Row[] = [];

        function buildFormation() {
          const RW = Math.min(540, W * 0.38);
          const RH = RW * 0.75;
          region = {
            x: Math.min(W * 0.56 + rand(-30, 30), W - RW - 40),
            y: Math.max(24, (H - RH) * 0.45 + rand(-24, 24)),
            w: RW,
            h: RH,
          };
          rows = [];
          const order: number[] = [];
          let ry = 0;
          while (ry < RH) {
            const rh = Math.min(rand(5, 16), RH - ry);
            order.push(rows.length);
            rows.push({
              ry,
              rh,
              delayIn: 0,
              delayOut: 0,
              slideDir: Math.random() < 0.5 ? -1 : 1,
              slideMag: rand(90, 340),
              ragL: rand(0, 46),
              ragR: rand(0, 46),
            });
            ry += rh;
          }
          // shuffled stagger so rows arrive/leave in scattered order
          for (let i = order.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [order[i], order[j]] = [order[j], order[i]];
          }
          order.forEach((rowI, k) => {
            rows[rowI].delayIn = k * IN_STAGGER;
            rows[rowI].delayOut = (order.length - 1 - k) * IN_STAGGER * 0.7;
          });
        }

        function drawStrip(
          img: HTMLImageElement,
          srcYFrac: number,
          dx: number,
          dy: number,
          dw: number,
          dh: number,
          scale: number
        ) {
          const sh = Math.min(img.height, Math.max(1, dh / scale));
          const sy = Math.min(img.height - sh, srcYFrac * (img.height - sh));
          ctx.drawImage(img, 0, sy, img.width, sh, dx, dy, dw, dh);
        }

        function drawFormationRow(img: HTMLImageElement, r: Row, offset: number, alpha: number) {
          if (alpha <= 0.01) return;
          const scaleY = region.h / img.height;
          const sy = r.ry / scaleY;
          const sh = r.rh / scaleY;
          // ragged trim on both ends (kept during hold -> torn-edge look)
          const la = r.ragL;
          const ra = r.ragR;
          const dw = region.w - la - ra;
          if (dw <= 2) return;
          const sx = (la / region.w) * img.width;
          const sw = (dw / region.w) * img.width;
          ctx.globalAlpha = alpha;
          ctx.drawImage(img, sx, sy, sw, sh, region.x + la + offset, region.y + r.ry, dw, r.rh);
        }

        function resize() {
          const dpr = Math.min(window.devicePixelRatio || 1, 2);
          W = container.clientWidth;
          H = container.clientHeight;
          canvas.width = Math.round(W * dpr);
          canvas.height = Math.round(H * dpr);
          canvas.style.width = W + 'px';
          canvas.style.height = H + 'px';
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          if (reducedMotion.matches && loadedCount === images.length) drawStatic();
        }

        let lastNow = 0;
        function drawFrame(now: number) {
          const dt = Math.min(0.05, (now - lastNow) / 1000 || 0.016);
          lastNow = now;
          ctx.clearRect(0, 0, W, H);

          // ambient weave
          for (let i = 0; i < ambients.length; i++) {
            const a = ambients[i];
            a.life += dt;
            a.x += a.vx * dt;
            if (a.life > a.maxLife || a.x > W + 60 || a.x + a.w < -60) {
              ambients[i] = spawnAmbient(false);
              continue;
            }
            const img = images[a.imgIdx];
            if (!img.complete || !img.naturalWidth) continue;
            const lifeFrac = a.life / a.maxLife;
            const fade = Math.min(1, Math.min(lifeFrac, 1 - lifeFrac) / 0.15);
            ctx.globalAlpha = a.alpha * fade;
            drawStrip(img, a.srcY, a.x, a.y, a.w, a.h, a.w / img.width);
          }
          ctx.globalAlpha = 1;

          // formation cycle
          const img = images[formIdx];
          const tPhase = (now - phaseStart) / 1000;
          if (img.complete && img.naturalWidth) {
            if (phase === 'gap') {
              if (tPhase > GAP_DUR) {
                buildFormation();
                phase = 'in';
                phaseStart = now;
              }
            } else if (phase === 'in') {
              let done = true;
              for (const r of rows) {
                const p = clamp01((tPhase - r.delayIn) / IN_DUR);
                if (p < 1) done = false;
                const e = easeOutCubic(p);
                drawFormationRow(img, r, r.slideDir * r.slideMag * (1 - e), e);
              }
              if (done) {
                phase = 'hold';
                phaseStart = now;
              }
            } else if (phase === 'hold') {
              for (const r of rows) drawFormationRow(img, r, 0, 1);
              if (tPhase > HOLD_DUR) {
                phase = 'out';
                phaseStart = now;
              }
            } else if (phase === 'out') {
              let done = true;
              for (const r of rows) {
                const p = clamp01((tPhase - r.delayOut) / OUT_DUR);
                if (p < 1) done = false;
                const e = easeInCubic(p);
                drawFormationRow(img, r, -r.slideDir * r.slideMag * 1.4 * e, 1 - e);
              }
              if (done) {
                formIdx = (formIdx + 1) % PROJECTS.length;
                phase = 'gap';
                phaseStart = now;
              }
            }
          }
          ctx.globalAlpha = 1;
        }

        function drawStatic() {
          // reduced-motion fallback: one aligned formation + static lines
          ctx.clearRect(0, 0, W, H);
          if (!rows.length) buildFormation();
          for (const a of ambients) {
            const img = images[a.imgIdx];
            if (!img.complete || !img.naturalWidth) continue;
            ctx.globalAlpha = a.alpha * 0.8;
            drawStrip(img, a.srcY, a.x, a.y, a.w, a.h, a.w / img.width);
          }
          ctx.globalAlpha = 1;
          const img = images[formIdx];
          if (img.complete && img.naturalWidth) {
            phase = 'hold';
            for (const r of rows) drawFormationRow(img, r, 0, 1);
          }
          ctx.globalAlpha = 1;
        }

        function inRegion(px: number, py: number) {
          return (
            px >= region.x &&
            px <= region.x + region.w &&
            py >= region.y &&
            py <= region.y + region.h
          );
        }

        function loop(now: number) {
          drawFrame(now);
          raf = requestAnimationFrame(loop);
        }

        function setRunning(next: boolean) {
          if (next === running) return;
          running = next;
          if (running) {
            lastNow = performance.now();
            raf = requestAnimationFrame(loop);
          } else {
            cancelAnimationFrame(raf);
          }
        }

        function start() {
          if (started) return;
          started = true;
          resize();
          for (let i = 0; i < AMBIENT_COUNT; i++) ambients.push(spawnAmbient(true));

          images.forEach((img, i) => {
            img.onload = () => {
              loadedCount++;
              if (reducedMotion.matches && loadedCount === images.length) drawStatic();
            };
            img.src = `${base}/images/works/${PROJECTS[i].slug}-thumb.png`;
          });

          window.addEventListener('resize', resize);

          canvas.addEventListener('mousemove', (e) => {
            const r = canvas.getBoundingClientRect();
            const active = phase === 'hold' || phase === 'in';
            canvas.style.cursor =
              active && inRegion(e.clientX - r.left, e.clientY - r.top) ? 'pointer' : 'default';
          });
          canvas.addEventListener('click', (e) => {
            const r = canvas.getBoundingClientRect();
            const active = phase === 'hold' || phase === 'in' || phase === 'out';
            if (active && inRegion(e.clientX - r.left, e.clientY - r.top)) {
              window.location.href = `${base}/works/${PROJECTS[formIdx].slug}`;
            }
          });

          if (!reducedMotion.matches) {
            phaseStart = performance.now();
            const io = new IntersectionObserver((entries) => {
              setRunning(entries[0].isIntersecting);
            });
            io.observe(container);
            setRunning(true);
          }
        }

        if (desktop.matches) {
          start();
        } else {
          desktop.addEventListener('change', (e) => {
            if (e.matches) start();
          });
        }
      })();
    </script>

    <!-- Hover-only scanline pulse on Featured Work thumbnails (shared module) -->
    <script>
      import { initScanlineHover } from '../scripts/scanline-cards';
      initScanlineHover();
    </script>
</Layout>
