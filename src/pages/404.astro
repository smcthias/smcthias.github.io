---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="Page Not Found - Savelle Design"
  description="That page doesn't exist — but your project still can. Explore Savelle Design's work, services, and free UX Health Check."
>
  <section>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-36">
      <div class="max-w-2xl">
        <p class="text-sm font-medium text-zinc-500 uppercase tracking-wider mb-6">404 — Page not found</p>
        <h1 class="text-4xl md:text-6xl font-bold text-zinc-900 mb-6 leading-tight">
          This page never came together.
        </h1>
        <p class="text-xl text-zinc-600 mb-8 leading-relaxed">
          The pieces are all here — they just don't add up to the page you were looking for.
          Your project, on the other hand, still can.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href={`${base}/works`}
            class="px-8 py-3 bg-zinc-900 text-white rounded-lg hover:bg-zinc-800 transition-colors font-medium"
          >
            See the Work
          </a>
          <a
            href={`${base}/services`}
            class="px-8 py-3 border-2 border-zinc-900 text-zinc-900 rounded-lg hover:bg-zinc-50 transition-colors font-medium"
          >
            Services
          </a>
          <a
            href={`${base}/contact`}
            class="px-8 py-3 border-2 border-zinc-900 text-zinc-900 rounded-lg hover:bg-zinc-50 transition-colors font-medium"
          >
            Get in Touch
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
