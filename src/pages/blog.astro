---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SectionDivider from '../components/SectionDivider.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Get all blog posts from content collections and sort by date (newest first)
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout
  title="Blog - Web Design & Development Insights | Savelle Design"
  description="Real-world insights on UX design, web development, branding, email marketing, and e-commerce. Learn from 18+ years of creating effective digital experiences for growing businesses."
>
    <!-- Hero Section -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold text-zinc-900 mb-6">Blog</h1>
      <p class="text-xl text-zinc-600 max-w-3xl">
        Insights from real projects: what works, what doesn't, and what I've learned building solutions for clients across industries.
      </p>
      </div>
    </section>

    <!-- Blog Posts Grid -->
    <section class="pb-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionDivider class="mb-12" />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        {sortedPosts.map((post) => {
          // Format date
          const date = new Date(post.data.date);
          const formattedDate = date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          });

          return (
          <a href={`${base}/blog/${post.slug}`} class="group block">
            <div class="relative aspect-[16/9] rounded-lg mb-6 overflow-hidden bg-zinc-100">
              <img
                src={`${base}/images/${post.data.image}`}
                alt={post.data.imageAlt}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="mb-2 flex items-center gap-3">
              <span class="text-sm font-medium text-zinc-500">{post.data.category}</span>
              <span class="text-sm text-zinc-400">•</span>
              <span class="text-sm text-zinc-500">{formattedDate}</span>
            </div>
            <h2 class="text-2xl font-bold text-zinc-900 mb-3 group-hover:text-zinc-600 transition-colors">
              {post.data.title}
            </h2>
            <p class="text-zinc-600 mb-4">
              {post.data.description}
            </p>
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag: string) => (
                <span class="px-3 py-1 bg-zinc-100 text-zinc-700 rounded-full text-sm">
                  {tag}
                </span>
              ))}
            </div>
          </a>
          );
        })}
      </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-zinc-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
            Ready to start your project?
          </h2>
          <p class="text-xl text-zinc-300 mb-8">
            Whether you need a landing page, email campaigns, or a complete brand refresh, let's discuss how I can help you achieve your goals.
          </p>
          <a
            href={`${base}/contact`}
            class="inline-block px-8 py-3 bg-white text-zinc-900 rounded-lg hover:bg-zinc-100 transition-colors font-medium"
          >
            Get in Touch
          </a>
        </div>
      </div>
    </section>

</Layout>
