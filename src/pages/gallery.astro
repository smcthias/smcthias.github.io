---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const images = [
  'branding-adorned',
  'branding-inboxinc',
  'branding-porkbun',
  'branding-seedlings',
  'email-lifewave',
  'ui-ifoodds',
  'ui-ifoodds-02',
  'ui-missioncommand',
  'ui-plexus',
  'ui-santa',
  'ui-yoli',
  'ui-yoli-02',
  'web-greencompass',
  'web-greencompass-02',
  'web-joyome',
  'web-joyome-02',
  'web-lamesa',
  'web-mikelove',
  'web-nikkl',
  'web-plexus-02',
  'web-suncard',
  'web-vanup',
  'web-vanup-02',
  'web-vanup-03',
  'web-vanup-04',
  'web-yoli',
  'web-yoli-02',
  'web-yoli-03',
  'web-youngliving',
];
---

<Layout
  title="Design Gallery - Savelle Design"
  description="A curated gallery of design work by Savelle McThias — web design, branding, logo design, ad creative, and digital product interfaces."
>
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold text-zinc-900 mb-6">
        Design Gallery
      </h1>
      <p class="text-xl text-zinc-600 max-w-3xl">
        A curated selection of design work spanning web, branding, mobile UI, and digital experiences.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="gallery-grid">
      {images.map((slug) => (
        <div
          class="gallery-item"
          data-full={`${base}/images/gallery/full/full-${slug}.jpg`}
          role="button"
          tabindex="0"
          aria-label="View full size image"
        >
          <img
            class="gallery-thumb"
            data-src={`${base}/images/gallery/thumbs/thumb-${slug}.jpg`}
            alt=""
          />
        </div>
      ))}
    </div>
  </div>

  <div id="gallery-modal" role="dialog" aria-modal="true" aria-label="Image viewer" aria-hidden="true">
    <button id="gallery-modal-close" aria-label="Close image viewer">&#x2715;</button>
    <div id="gallery-modal-loading" aria-hidden="true">
      <div class="modal-spinner"></div>
    </div>
    <img id="gallery-modal-img" src="" alt="" />
  </div>
</Layout>

<style>
  /* ── Masonry Grid ── */
  .gallery-grid {
    columns: 4;
    column-gap: 16px;
  }

  @media (max-width: 1280px) { .gallery-grid { columns: 3; } }
  @media (max-width: 768px)  { .gallery-grid { columns: 2; } }
  @media (max-width: 480px)  { .gallery-grid { columns: 1; } }

  .gallery-item {
    break-inside: avoid;
    margin-bottom: 16px;
    cursor: pointer;
    overflow: hidden;
    background: #f4f4f5;
    position: relative;
    min-height: 120px;
    border-radius: 0.5rem;
  }

  /* Shimmer placeholder */
  .gallery-item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(0, 0, 0, 0.04) 50%,
      transparent 100%
    );
    animation: gallery-shimmer 1.8s infinite;
    z-index: 1;
    pointer-events: none;
  }

  .gallery-item.img-loaded::before {
    display: none;
  }

  @keyframes gallery-shimmer {
    from { transform: translateX(-100%); }
    to   { transform: translateX(100%); }
  }

  .gallery-thumb {
    display: block;
    width: 100%;
    height: auto;
    opacity: 0;
    transition: opacity 0.45s ease, transform 0.35s ease, filter 0.35s ease;
    position: relative;
    z-index: 2;
  }

  .gallery-thumb.loaded {
    opacity: 1;
  }

  .gallery-item:hover .gallery-thumb {
    transform: scale(1.03);
    filter: brightness(1.03);
  }

  /* ── Modal ── */
  #gallery-modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    z-index: 1000;
    overflow: auto;
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 64px 24px 40px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.22s ease, visibility 0.22s ease;
  }

  #gallery-modal.open {
    opacity: 1;
    visibility: visible;
  }

  #gallery-modal-close {
    position: fixed;
    top: 16px;
    right: 20px;
    background: rgba(255, 255, 255, 0.15);
    border: none;
    color: #f4f4f5;
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 1001;
  }

  #gallery-modal-close:hover {
    background: rgba(255, 255, 255, 0.28);
  }

  #gallery-modal-img {
    display: block;
    max-width: calc(100vw - 48px);
    height: auto;
    cursor: default;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  #gallery-modal-img.loaded {
    opacity: 1;
  }

  #gallery-modal-loading {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 1002;
  }

  #gallery-modal-loading.hidden {
    display: none;
  }

  .modal-spinner {
    width: 36px;
    height: 36px;
    border: 3px solid rgba(255, 255, 255, 0.2);
    border-top-color: rgba(255, 255, 255, 0.85);
    border-radius: 50%;
    animation: modal-spin 0.75s linear infinite;
  }

  @keyframes modal-spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  // ── Lazy Loading via IntersectionObserver ──
  const thumbs = document.querySelectorAll<HTMLImageElement>('.gallery-thumb');

  const lazyObserver = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        const img = entry.target as HTMLImageElement;
        const src = img.dataset.src;
        if (!src) continue;
        img.src = src;
        const reveal = () => {
          img.classList.add('loaded');
          img.closest('.gallery-item')?.classList.add('img-loaded');
        };
        img.onload = reveal;
        img.onerror = reveal;
        lazyObserver.unobserve(img);
      }
    },
    { rootMargin: '300px 0px' }
  );

  thumbs.forEach((img) => lazyObserver.observe(img));

  // ── Modal ──
  const modal    = document.getElementById('gallery-modal')!;
  const modalImg = document.getElementById('gallery-modal-img') as HTMLImageElement;
  const closeBtn = document.getElementById('gallery-modal-close')!;

  function openModal(src: string) {
    const loading = document.getElementById('gallery-modal-loading')!;
    modalImg.classList.remove('loaded');
    loading.classList.remove('hidden');
    modalImg.src = src;
    const onDone = () => {
      loading.classList.add('hidden');
      modalImg.classList.add('loaded');
    };
    modalImg.onload = onDone;
    modalImg.onerror = onDone;
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeModal() {
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    setTimeout(() => {
      modalImg.src = '';
      modalImg.classList.remove('loaded');
      document.getElementById('gallery-modal-loading')!.classList.remove('hidden');
    }, 230);
    document.body.style.overflow = '';
  }

  // Open on thumbnail click or keyboard
  document.querySelectorAll<HTMLElement>('.gallery-item').forEach((item) => {
    item.addEventListener('click', () => {
      const full = item.dataset.full;
      if (full) openModal(full);
    });
    item.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        const full = item.dataset.full;
        if (full) openModal(full);
      }
    });
  });

  // Close on backdrop click (not on image)
  modal.addEventListener('click', (e) => {
    if (e.target !== modalImg) closeModal();
  });

  // Close button
  closeBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    closeModal();
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
  });
</script>
