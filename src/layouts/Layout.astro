---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "Digital Experience Leader & UX/UI Designer in Scottsdale, AZ. 18+ years transforming business objectives into exceptional user experiences.", image = "/images/og-default.jpg" } = Astro.props;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalURL = new URL(currentPath, Astro.site || 'https://savelledesign.com');
const ogImage = new URL(image, Astro.site || 'https://savelledesign.com');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Savelle Design" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Additional SEO -->
    <meta name="author" content="Savelle McThias" />
    <meta name="robots" content="index, follow" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-white text-zinc-900 min-h-screen">
    <nav class="sticky top-0 z-50 bg-white border-b border-zinc-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <a href={`${base}/`} class="text-xl font-bold text-zinc-900 hover:text-zinc-700 transition-colors">
            Savelle Design
          </a>

          <!-- Desktop Navigation -->
          <div class="hidden md:flex space-x-8">
            <a
              href={`${base}/`}
              class={`hover:text-zinc-600 transition-colors ${currentPath === base || currentPath === `${base}/` ? 'text-zinc-900 font-semibold' : 'text-zinc-700'}`}
            >
              Home
            </a>
            <a
              href={`${base}/services`}
              class={`hover:text-zinc-600 transition-colors ${currentPath.includes('/services') ? 'text-zinc-900 font-semibold' : 'text-zinc-700'}`}
            >
              Services
            </a>
            <a
              href={`${base}/works`}
              class={`hover:text-zinc-600 transition-colors ${currentPath.includes('/works') ? 'text-zinc-900 font-semibold' : 'text-zinc-700'}`}
            >
              Works
            </a>
            <a
              href={`${base}/about`}
              class={`hover:text-zinc-600 transition-colors ${currentPath.includes('/about') ? 'text-zinc-900 font-semibold' : 'text-zinc-700'}`}
            >
              About
            </a>
            <a
              href={`${base}/blog`}
              class={`hover:text-zinc-600 transition-colors ${currentPath.includes('/blog') ? 'text-zinc-900 font-semibold' : 'text-zinc-700'}`}
            >
              Blog
            </a>
            <a
              href={`${base}/contact`}
              class={`hover:text-zinc-600 transition-colors ${currentPath.includes('/contact') ? 'text-zinc-900 font-semibold' : 'text-zinc-700'}`}
            >
              Contact
            </a>
          </div>

          <!-- Mobile Menu Button -->
          <button id="mobile-menu-button" class="md:hidden p-2 rounded-lg hover:bg-zinc-100 transition-colors" aria-label="Toggle menu">
            <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Navigation Menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-zinc-200">
        <div class="px-4 py-4 space-y-3">
          <a
            href={`${base}/`}
            class={`block py-2 hover:text-zinc-600 transition-colors ${currentPath === base || currentPath === `${base}/` ? 'text-zinc-900 font-semibold' : 'text-zinc-700'}`}
          >
            Home
          </a>
          <a
            href={`${base}/services`}
            class={`block py-2 hover:text-zinc-600 transition-colors ${currentPath.includes('/services') ? 'text-zinc-900 font-semibold' : 'text-zinc-700'}`}
          >
            Services
          </a>
          <a
            href={`${base}/works`}
            class={`block py-2 hover:text-zinc-600 transition-colors ${currentPath.includes('/works') ? 'text-zinc-900 font-semibold' : 'text-zinc-700'}`}
          >
            Works
          </a>
          <a
            href={`${base}/about`}
            class={`block py-2 hover:text-zinc-600 transition-colors ${currentPath.includes('/about') ? 'text-zinc-900 font-semibold' : 'text-zinc-700'}`}
          >
            About
          </a>
          <a
            href={`${base}/blog`}
            class={`block py-2 hover:text-zinc-600 transition-colors ${currentPath.includes('/blog') ? 'text-zinc-900 font-semibold' : 'text-zinc-700'}`}
          >
            Blog
          </a>
          <a
            href={`${base}/contact`}
            class={`block py-2 hover:text-zinc-600 transition-colors ${currentPath.includes('/contact') ? 'text-zinc-900 font-semibold' : 'text-zinc-700'}`}
          >
            Contact
          </a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="bg-zinc-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="text-center text-zinc-400 text-sm">
          <p>&copy; {new Date().getFullYear()} Savelle Design. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "Savelle Design",
        "description": "Digital Experience Leader & UX/UI Designer specializing in landing pages, website refresh, brand identity, and email campaigns for growing businesses.",
        "url": "https://savelledesign.com",
        "logo": "https://savelledesign.com/favicon.svg",
        "image": "https://savelledesign.com/images/og-default.jpg",
        "founder": {
          "@type": "Person",
          "name": "Savelle McThias",
          "jobTitle": "UX/UI Designer & Developer",
          "email": "savellem@gmail.com",
          "telephone": "+1-602-931-1474",
          "url": "https://savelledesign.com/about"
        },
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Scottsdale",
          "addressRegion": "AZ",
          "addressCountry": "US"
        },
        "areaServed": "Worldwide",
        "priceRange": "$$",
        "sameAs": [
          "https://linkedin.com"
        ]
      }
    </script>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-family: 'Plus Jakarta Sans', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
</style>

<script>
  // Mobile menu toggle functionality
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  mobileMenuButton?.addEventListener('click', () => {
    const isHidden = mobileMenu?.classList.contains('hidden');

    if (isHidden) {
      mobileMenu?.classList.remove('hidden');
      menuIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
    } else {
      mobileMenu?.classList.add('hidden');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    }
  });

  // Close mobile menu when clicking on a link
  const mobileMenuLinks = mobileMenu?.querySelectorAll('a');
  mobileMenuLinks?.forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    });
  });
</script>
